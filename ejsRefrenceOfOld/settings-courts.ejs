<% var currentPage = 'settings-courts'; %>
<% var canManageLocations = adminUser && adminUser.role === 2; %>
<% var settingsHomeHref = canManageLocations ? '/admin/settings' : '/admin/settings/staff'; %>
<%
  var selectedVenueName = '';
  if (typeof venues !== 'undefined' && venues.length && typeof selectedVenueId !== 'undefined' && selectedVenueId) {
    var _sv = venues.find(function(v){ return v.id == selectedVenueId; });
    if (_sv) selectedVenueName = _sv.title;
  }
%>

<style>
  .cts-sidebar { width: 225px; background: #F8F9FB; padding: 16px 0; flex-shrink: 0; }
  .cts-sidebar-title { padding: 12px 16px 12px; border-bottom: 1px solid #E7EBEF; margin-bottom: 12px; }
  .cts-sidebar-title h2 { font-size: 14px; font-weight: 600; color: #0A0A0A; line-height: 20px; }
  .cts-sidebar-nav { display: flex; flex-direction: column; gap: 4px; padding: 0 16px; }
  .cts-sidebar-nav a {
    display: flex; align-items: center; gap: 8px; padding: 6px 8px;
    border-radius: 8px; font-size: 14px; font-weight: 400; color: #737373;
    line-height: 20px; text-decoration: none; transition: background 0.15s;
  }
  .cts-sidebar-nav a:hover { background: rgba(141, 153, 174, 0.1); }
  .cts-sidebar-nav a.active { background: #EEF2FF; color: #2B2D42; font-weight: 500; }
  .cts-sidebar-nav a svg { width: 16px; height: 16px; flex-shrink: 0; }

  .cts-header { background: #FFFFFF; display: flex; align-items: center; justify-content: space-between; padding: 12px 24px; }
  .cts-breadcrumb { display: flex; align-items: center; gap: 8px; }
  .cts-breadcrumb a { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #8D99AE; text-decoration: none; }
  .cts-breadcrumb a:hover { color: #2B2D42; }
  .cts-breadcrumb .sep { font-size: 12px; color: rgba(141, 153, 174, 0.4); }
  .cts-breadcrumb .mid { font-size: 12px; font-weight: 400; color: #8D99AE; }

  .cts-title-bar { background: #FFFFFF; display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; }
  .cts-title-bar h1 { font-size: 16px; font-weight: 700; color: #2B2D42; line-height: 24px; }
  .cts-title-bar p { font-size: 12px; font-weight: 400; color: #8D99AE; line-height: 16px; margin-top: 2px; }

  .cts-content-area { background: #F2F4F7; flex: 1; overflow-y: auto; }
  .cts-content-inner { padding: 20px 24px 28px; max-width: 760px; }

  .cts-sport-block { margin-bottom: 14px; }
  .cts-sport-card {
    background: #FFFFFF; border: 1px solid #DDE3EC; border-radius: 12px; overflow: hidden;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.03);
  }
  .cts-sport-header {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; padding: 14px 16px 12px; border-bottom: 1px solid #EEF2F6;
  }
  .cts-sport-name { font-size: 14px; font-weight: 600; color: #2B2D42; }
  .cts-sport-count { flex-shrink: 0; font-size: 12px; font-weight: 500; color: #94A3B8; }

  .cts-courts-list { display: flex; flex-direction: column; }
  .cts-court-row {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 10px 16px; border-bottom: 1px solid #EEF2F6;
  }
  .cts-court-row:last-child { border-bottom: none; }
  .cts-court-row-main { display: flex; align-items: center; gap: 12px; min-width: 0; flex: 1; }
  .cts-court-thumb {
    width: 114px; height: 58px; border-radius: 4px; object-fit: cover; flex-shrink: 0;
    border: 1px solid #E7EBEF; background: #E2E8F0;
  }
  .cts-court-thumb-placeholder {
    width: 114px; height: 58px; border-radius: 4px; flex-shrink: 0;
    border: 1px solid #E7EBEF; background: #E2E8F0;
    display: flex; align-items: center; justify-content: center;
  }
  .cts-court-thumb-placeholder svg { width: 22px; height: 22px; color: #94A3B8; }
  .cts-court-info { min-width: 0; }
  .cts-court-title { font-size: 15px; font-weight: 600; line-height: 22px; color: #2B2D42; margin: 0 0 2px; }
  .cts-court-meta { font-size: 12px; font-weight: 400; line-height: 18px; color: #5F6C85; margin: 0; }
  .cts-court-actions { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
  .cts-court-action-btn {
    width: 28px; height: 28px; border-radius: 6px; border: none; background: transparent;
    display: flex; align-items: center; justify-content: center; cursor: pointer; padding: 0;
  }
  .cts-court-action-btn:hover { background: rgba(141, 153, 174, 0.1); }
  .cts-court-action-btn.delete:hover { background: #FEF2F2; }
  .cts-court-action-btn svg { width: 14px; height: 14px; }

  .cts-editor-card {
    background: #FFFFFF; border: 1px solid #DDE3EC; border-radius: 12px; overflow: hidden;
    margin-top: 12px; display: none;
  }
  .cts-editor-card.visible { display: block; }
  .cts-editor-title-row {
    display: flex; align-items: center; gap: 12px; padding: 12px 16px;
    border-bottom: 1px solid #EEF2F6;
  }
  .cts-editor-title-wrap { flex: 1; }
  .cts-editor-title-input {
    width: 100%; height: 30px; border: 1px solid #EEF2F6; border-radius: 5px; background: #FFFFFF;
    padding: 0 10px; font-size: 13px; font-weight: 500; color: #2B2D42; outline: none; box-sizing: border-box;
  }
  .cts-editor-title-input::placeholder { color: #94A3B8; }
  .cts-editor-title-input:focus { border-color: #CBD5E1; box-shadow: 0 0 0 2px rgba(148,163,184,0.12); }

  .cts-editor-body { padding: 14px 16px 10px; }
  .cts-form-row {
    display: grid; grid-template-columns: 120px 1fr; gap: 16px; align-items: start;
    padding: 2px 0 16px;
  }
  .cts-form-row + .cts-form-row { border-top: 1px solid #EEF2F6; padding-top: 14px; }
  .cts-form-label { font-size: 13px; font-weight: 600; color: #2B2D42; line-height: 20px; padding-top: 7px; }

  .cts-upload-area { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .cts-upload-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    min-width: 120px; height: 34px; padding: 0 14px; border: 1px solid #D7DEE8; border-radius: 6px;
    background: #FFFFFF; font-size: 13px; font-weight: 500; color: #94A3B8; cursor: pointer;
    box-shadow: 0 1px 2px rgba(15,23,42,0.04);
  }
  .cts-upload-btn:hover { background: #F8FAFC; }
  .cts-upload-btn svg { width: 14px; height: 14px; }
  .cts-image-preview {
    width: 80px; height: 48px; border-radius: 4px; object-fit: cover;
    border: 1px solid #E7EBEF; display: none;
  }
  .cts-image-preview.visible { display: block; }

  .cts-editor-textarea {
    width: 100%; min-height: 68px; padding: 10px 12px; border: 1px solid #DDE3EC; border-radius: 6px;
    font-size: 13px; line-height: 20px; color: #5F6C85; resize: none; outline: none;
    box-sizing: border-box; font-family: inherit;
  }
  .cts-editor-textarea:focus { border-color: #CBD5E1; box-shadow: 0 0 0 2px rgba(148,163,184,0.12); }

  .cts-editor-footer { display: flex; align-items: center; justify-content: flex-end; gap: 8px; padding: 0 16px 14px; }
  .cts-inline-save-btn {
    height: 32px; padding: 0 18px; border: none; border-radius: 5px; background: #2B2D42;
    color: #FFFFFF; font-size: 13px; font-weight: 500; cursor: pointer;
  }
  .cts-inline-save-btn:hover { background: #1a1b2e; }
  .cts-inline-save-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .cts-cancel-btn {
    height: 32px; padding: 0 14px; border: 1px solid #D7DEE8; border-radius: 5px; background: #FFFFFF;
    color: #5F6C85; font-size: 13px; font-weight: 500; cursor: pointer;
  }
  .cts-cancel-btn:hover { background: #F8FAFC; }

  .cts-add-court-btn {
    display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%;
    min-height: 42px; margin-top: 12px; border-radius: 12px; border: 1px dashed #CBD5E1;
    background: transparent; color: #94A3B8; font-size: 13px; font-weight: 500; cursor: pointer;
    transition: all 0.15s;
  }
  .cts-add-court-btn:hover { background: #EEF2FF; border-color: #A5B4FC; color: #6366F1; }
  .cts-add-court-btn svg { width: 14px; height: 14px; }

  .cts-empty-state { padding: 20px 16px; text-align: center; font-size: 13px; color: #94A3B8; }

  @keyframes ctsSpin { to { transform: rotate(360deg); } }
  .cts-spin { animation: ctsSpin 0.75s linear infinite; display:inline-block; vertical-align:middle; margin-right:4px; }

  @media (max-width: 768px) {
    .cts-content-inner { padding: 16px; }
    .cts-form-row { grid-template-columns: 1fr; gap: 10px; }
    .cts-form-label { padding-top: 0; }
    .cts-court-row-main { flex-direction: column; align-items: flex-start; }
    .cts-court-thumb, .cts-court-thumb-placeholder { width: 100%; max-width: 220px; height: 110px; }
  }
</style>

<div style="display: flex; height: 100vh;">
  <%- include('partials/settings-sidebar', { active: 'courts' }) %>

  <!-- Main Content Column -->
  <div style="flex: 1; display: flex; flex-direction: column; min-width: 0;">
    <!-- Header / Breadcrumb -->
    <div class="cts-header">
      <div class="cts-breadcrumb">
        <a href="<%= settingsHomeHref %>">
          <svg width="14" height="14" fill="none" stroke="#8D99AE" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4" d="M15 19l-7-7 7-7"/></svg>
          Settings
        </a>
        <span class="sep">/</span>
        <% if (selectedVenueName) { %>
          <span class="mid">Courts</span>
          <span class="sep">/</span>
          <span class="mid" style="color:#2B2D42; font-weight:600;"><%= selectedVenueName %></span>
        <% } else { %>
          <span class="mid">Courts</span>
        <% } %>
      </div>
      <% if (canManageLocations) { %>
        <div class="venue-select-wrap">
          <svg class="venue-pin-icon" fill="none" stroke="#8D99AE" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <select class="venue-location-select" id="courts-venue-select">
            <% if (typeof venues !== 'undefined' && venues.length) { %>
              <% venues.forEach(function(v) { %>
                <option value="<%= v.id %>" <%= (typeof selectedVenueId !== 'undefined' && selectedVenueId == v.id) ? 'selected' : '' %>><%= v.title %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
      <% } %>
    </div>
    <hr style="margin:0; border:none; border-top:1px solid #E7EBEF;">

    <!-- Title Bar -->
    <div class="cts-title-bar">
      <div>
        <h1>Courts</h1>
        <p>Manage the courts available at this location.</p>
      </div>
    </div>

    <!-- Content Area -->
    <div class="cts-content-area">
      <div class="cts-content-inner">

        <% if (!selectedVenueId) { %>
          <div style="text-align:center; padding:40px 0; color:#94A3B8; font-size:14px;">
            No location selected. Please select a location from the dropdown above.
          </div>
        <% } else if (!venueSportTypes || venueSportTypes.length === 0) { %>
          <div style="text-align:center; padding:40px 0; color:#94A3B8; font-size:14px;">
            No sport types configured for this location. Add sport types in
            <a href="/admin/settings" style="color:#6366F1;">Locations</a> settings.
          </div>
        <% } else { %>

          <% venueSportTypes.forEach(function(st) { %>
            <% var courts = courtsBySportType[st.id] || []; %>
            <div class="cts-sport-block" id="block-<%= st.id %>">
              <div class="cts-sport-card">
                <div class="cts-sport-header">
                  <span class="cts-sport-name"><%= st.name %></span>
                  <span class="cts-sport-count" id="count-<%= st.id %>"><%= courts.length %> Court<%= courts.length !== 1 ? 's' : '' %></span>
                </div>
                <div class="cts-courts-list" id="list-<%= st.id %>">
                  <% if (courts.length === 0) { %>
                    <div class="cts-empty-state" id="empty-<%= st.id %>">No courts yet. Add one below.</div>
                  <% } %>
                  <% courts.forEach(function(c) { %>
                    <div class="cts-court-row"
                      data-court-id="<%= c.id %>"
                      data-sport-id="<%= st.id %>"
                      data-court-title="<%= (c.title || '').replace(/"/g, '&quot;') %>"
                      data-court-desc="<%= (c.description || '').replace(/"/g, '&quot;') %>"
                      data-court-image="<%= c.image || '' %>">
                      <div class="cts-court-row-main">
                        <% if (c.image) { %>
                          <img class="cts-court-thumb" src="/<%= c.image %>" alt="<%= c.title %>">
                        <% } else { %>
                          <div class="cts-court-thumb-placeholder">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                          </div>
                        <% } %>
                        <div class="cts-court-info">
                          <p class="cts-court-title"><%= c.title %></p>
                          <p class="cts-court-meta"><%= c.description || '' %></p>
                        </div>
                      </div>
                      <div class="cts-court-actions">
                        <button type="button" class="cts-court-action-btn js-edit-court" aria-label="Edit court">
                          <svg fill="none" stroke="#94A3B8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                        </button>
                        <button type="button" class="cts-court-action-btn delete js-delete-court" aria-label="Delete court">
                          <svg fill="none" stroke="#94A3B8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        </button>
                      </div>
                    </div>
                  <% }); %>
                </div>
              </div>

              <!-- Inline editor -->
              <div class="cts-editor-card" id="editor-<%= st.id %>" data-sport-id="<%= st.id %>">
                <div class="cts-editor-title-row">
                  <div class="cts-editor-title-wrap">
                    <input class="cts-editor-title-input" type="text" placeholder="Court Name"
                      id="title-<%= st.id %>" aria-label="Court name">
                  </div>
                  <button type="button" class="cts-court-action-btn delete js-cancel-editor" aria-label="Close editor">
                    <svg fill="none" stroke="#94A3B8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
                  </button>
                </div>
                <div class="cts-editor-body">
                  <div class="cts-form-row">
                    <div class="cts-form-label">Image</div>
                    <div class="cts-upload-area">
                      <label class="cts-upload-btn" for="img-<%= st.id %>">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 4v16m8-8H4"/></svg>
                        Add Photo
                      </label>
                      <input type="file" id="img-<%= st.id %>" accept="image/*" style="display:none;">
                      <img class="cts-image-preview" id="preview-<%= st.id %>" src="" alt="Preview">
                    </div>
                  </div>
                  <div class="cts-form-row">
                    <div class="cts-form-label">Description</div>
                    <div>
                      <textarea class="cts-editor-textarea" id="desc-<%= st.id %>"
                        placeholder="e.g. Tennis, Double, Artificial Grass, Outdoor"
                        aria-label="Court description"></textarea>
                    </div>
                  </div>
                </div>
                <div class="cts-editor-footer">
                  <button type="button" class="cts-cancel-btn js-cancel-editor">Cancel</button>
                  <button type="button" class="cts-inline-save-btn js-save-court" id="save-btn-<%= st.id %>">Save</button>
                </div>
                <input type="hidden" class="js-editing-id" value="">
                <input type="hidden" class="js-existing-image" value="">
                <input type="hidden" class="js-sport-type-id" value="<%= st.id %>">
              </div>

              <button type="button" class="cts-add-court-btn js-add-court" id="add-btn-<%= st.id %>"
                data-sport-id="<%= st.id %>">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Add Court
              </button>
            </div>
          <% }); %>

        <% } %>

      </div>
    </div>
  </div>
</div>

<script>
$(document).ready(function () {

  // Venue change is handled centrally in layout.ejs (overlay + reload).

  // ── Image file inputs (don't bubble — wire directly) ──
  document.querySelectorAll('.cts-editor-card').forEach(function (editor) {
    var stId = editor.dataset.sportId;
    var fileInput = document.getElementById('img-' + stId);
    if (!fileInput) return;
    fileInput.addEventListener('change', function () {
      if (!fileInput.files || !fileInput.files[0]) return;
      var reader = new FileReader();
      reader.onload = function (e) {
        var preview = document.getElementById('preview-' + stId);
        preview.src = e.target.result;
        preview.classList.add('visible');
      };
      reader.readAsDataURL(fileInput.files[0]);
    });
  });

  // ── Event delegation ──
  $(document).on('click', '.js-add-court', function () {
    showAddEditor($(this).data('sport-id'));
  });

  $(document).on('click', '.js-edit-court', function () {
    var row = $(this).closest('.cts-court-row');
    openEditor(row.data('sport-id'), {
      id:    row.data('court-id'),
      title: row.data('court-title'),
      desc:  row.data('court-desc'),
      image: row.data('court-image'),
    });
  });

  $(document).on('click', '.js-delete-court', function () {
    var row = $(this).closest('.cts-court-row');
    handleDelete(row.data('court-id'), row.data('sport-id'));
  });

  $(document).on('click', '.js-cancel-editor', function () {
    cancelEditor($(this).closest('.cts-editor-card').data('sport-id'));
  });

  $(document).on('click', '.js-save-court', function () {
    saveCourt($(this).closest('.cts-editor-card').data('sport-id'));
  });

  // ── Editor helpers ──
  function showAddEditor(stId) {
    resetEditor(stId);
    $('#editor-' + stId).addClass('visible');
    $('#add-btn-' + stId).hide();
    $('#title-' + stId).focus();
  }

  function openEditor(stId, court) {
    resetEditor(stId);
    var editor = document.getElementById('editor-' + stId);
    editor.querySelector('.js-editing-id').value    = court.id;
    editor.querySelector('.js-existing-image').value = court.image || '';
    $('#title-' + stId).val(court.title || '');
    $('#desc-'  + stId).val(court.desc  || '');
    if (court.image) {
      $('#preview-' + stId).attr('src', '/' + court.image).addClass('visible');
    }
    $('#editor-' + stId).addClass('visible');
    $('#add-btn-' + stId).hide();
    $('#title-' + stId).focus();
  }

  function cancelEditor(stId) {
    resetEditor(stId);
    $('#editor-' + stId).removeClass('visible');
    $('#add-btn-' + stId).show();
  }

  function resetEditor(stId) {
    var editor = document.getElementById('editor-' + stId);
    if (!editor) return;
    editor.querySelector('.js-editing-id').value    = '';
    editor.querySelector('.js-existing-image').value = '';
    $('#title-'   + stId).val('');
    $('#desc-'    + stId).val('');
    var fi = document.getElementById('img-' + stId);
    if (fi) fi.value = '';
    $('#preview-' + stId).attr('src', '').removeClass('visible');
  }

  // ── Save (create or update) ──
  function saveCourt(stId) {
    var title = $('#title-' + stId).val().trim();
    if (!title) {
      Swal.fire($.extend({}, window.swalTheme, {
        icon: 'warning',
        title: 'Required',
        text: 'Please enter a court name.',
      }));
      $('#title-' + stId).focus();
      return;
    }

    var editor      = document.getElementById('editor-' + stId);
    var editingId   = editor.querySelector('.js-editing-id').value;
    var sportTypeId = editor.querySelector('.js-sport-type-id').value;
    var description = $('#desc-' + stId).val().trim();
    var fileInput   = document.getElementById('img-' + stId);

    var formData = new FormData();
    formData.append('title', title);
    formData.append('description', description);
    formData.append('sport_type_id', sportTypeId);
    if (fileInput && fileInput.files[0]) {
      formData.append('court_image', fileInput.files[0]);
    }

    var url = editingId
      ? '/admin/settings/courts/' + editingId + '/update'
      : '/admin/settings/courts/create';

    var btn = document.getElementById('save-btn-' + stId);
    btn.disabled = true;
    btn.innerHTML = '<svg class="cts-spin" fill="none" viewBox="0 0 24 24" width="14" height="14" style="stroke:white"><circle cx="12" cy="12" r="9" stroke-width="3" stroke-dasharray="28 56" stroke-linecap="round"/></svg> Saving…';

    fetch(url, { method: 'POST', body: formData, credentials: 'same-origin' })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        btn.disabled = false;
        btn.textContent = 'Save';

        if (!data.success) {
          Swal.fire($.extend({}, window.swalTheme, {
            icon: 'error',
            title: 'Error',
            text: data.message || 'Failed to save court.',
          }));
          return;
        }

        Swal.fire($.extend({}, window.swalTheme, {
          icon: 'success',
          title: editingId ? 'Court Updated' : 'Court Added',
          text: data.message || 'Saved successfully.',
          timer: 1800,
          showConfirmButton: false,
        }));

        cancelEditor(stId);
        if (editingId) {
          updateRow(editingId, stId, data.data);
        } else {
          appendRow(stId, data.data);
        }
        refreshCount(stId);
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = 'Save';
        Swal.fire($.extend({}, window.swalTheme, {
          icon: 'error',
          title: 'Network Error',
          text: 'Please try again.',
        }));
      });
  }

  // ── Delete ──
  function handleDelete(courtId, stId) {
    Swal.fire($.extend({}, window.swalTheme, {
      title: 'Delete Court?',
      text: 'This court will be permanently removed.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Yes, delete it',
    })).then(function (result) {
      if (!result.isConfirmed) return;

      fetch('/admin/settings/courts/' + courtId + '/delete', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: '{}',
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.success) {
            Swal.fire($.extend({}, window.swalTheme, { icon: 'error', title: 'Error', text: data.message || 'Failed to delete.' }));
            return;
          }
          var row = document.querySelector('.cts-court-row[data-court-id="' + courtId + '"]');
          if (row) row.remove();
          refreshCount(stId);

          var list = document.getElementById('list-' + stId);
          if (list && !list.querySelector('.cts-court-row')) {
            list.insertAdjacentHTML('beforeend',
              '<div class="cts-empty-state" id="empty-' + stId + '">No courts yet. Add one below.</div>');
          }

          Swal.fire($.extend({}, window.swalTheme, {
            icon: 'success',
            title: 'Deleted!',
            text: 'Court has been deleted.',
            timer: 1800,
            showConfirmButton: false,
          }));
        })
        .catch(function () {
          Swal.fire($.extend({}, window.swalTheme, { icon: 'error', title: 'Network Error', text: 'Please try again.' }));
        });
    });
  }

  // ── DOM helpers ──
  function buildThumbHtml(image, title) {
    if (image) {
      return '<img class="cts-court-thumb" src="/' + escAttr(image) + '" alt="' + escAttr(title) + '">';
    }
    return '<div class="cts-court-thumb-placeholder">' +
      '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
      '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4" ' +
      'd="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14' +
      'm-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>' +
      '</svg></div>';
  }

  function buildRowHtml(stId, c) {
    return '<div class="cts-court-row"' +
      ' data-court-id="' + c.id + '"' +
      ' data-sport-id="' + stId + '"' +
      ' data-court-title="' + escAttr(c.title || '') + '"' +
      ' data-court-desc="' + escAttr(c.description || '') + '"' +
      ' data-court-image="' + escAttr(c.image || '') + '">' +
      '<div class="cts-court-row-main">' +
        buildThumbHtml(c.image, c.title) +
        '<div class="cts-court-info">' +
          '<p class="cts-court-title">' + escHtml(c.title) + '</p>' +
          '<p class="cts-court-meta">' + escHtml(c.description || '') + '</p>' +
        '</div>' +
      '</div>' +
      '<div class="cts-court-actions">' +
        '<button type="button" class="cts-court-action-btn js-edit-court" aria-label="Edit court">' +
          '<svg fill="none" stroke="#94A3B8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>' +
        '</button>' +
        '<button type="button" class="cts-court-action-btn delete js-delete-court" aria-label="Delete court">' +
          '<svg fill="none" stroke="#94A3B8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>' +
        '</button>' +
      '</div>' +
    '</div>';
  }

  function appendRow(stId, court) {
    $('#empty-' + stId).remove();
    $('#list-' + stId).append(buildRowHtml(stId, court));
  }

  function updateRow(courtId, stId, court) {
    var old = document.querySelector('.cts-court-row[data-court-id="' + courtId + '"]');
    if (!old) return;
    var tmp = document.createElement('div');
    tmp.innerHTML = buildRowHtml(stId, court);
    old.replaceWith(tmp.firstElementChild);
  }

  function refreshCount(stId) {
    var n = $('#list-' + stId + ' .cts-court-row').length;
    $('#count-' + stId).text(n + ' Court' + (n !== 1 ? 's' : ''));
  }

  function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function escAttr(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

});
</script>
