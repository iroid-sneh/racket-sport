<style>
  .autocomplete-wrapper { position: relative; }
  .autocomplete-dropdown {
    position: absolute; top: 100%; left: 0; right: 0; z-index: 50;
    background: white; border: 1px solid #d1d5db; border-top: none;
    border-radius: 0 0 0.5rem 0.5rem; max-height: 200px; overflow-y: auto;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
  }
  .autocomplete-dropdown .ac-item {
    padding: 0.5rem 1rem; cursor: pointer; font-size: 0.875rem; color: #374151;
    border-bottom: 1px solid #f3f4f6;
  }
  .autocomplete-dropdown .ac-item:hover { background: #f3f4f6; }
  .autocomplete-dropdown .ac-item:last-child { border-bottom: none; }
  .autocomplete-dropdown .ac-loading { padding: 0.5rem 1rem; font-size: 0.75rem; color: #9ca3af; }
</style>

<div class="rounded-xl shadow-md bg-white overflow-hidden">
  <div class="p-6 border-b border-gray-200">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div class="flex items-center gap-3">
        <% if (!isOwner) { %>
          <a href="/admin/clubs" class="text-gray-500 hover:text-gray-700">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          </a>
        <% } %>
        <h3 class="text-lg font-semibold text-gray-800">
          <% if (isOwner) { %>My Venues<% } else { %>Venues - <%= clubAdmin.name %><% } %>
        </h3>
      </div>
      <% if (isOwner) { %>
        <button type="button" onclick="document.getElementById('add-modal').classList.remove('hidden')" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 text-sm font-medium whitespace-nowrap">
          Add Venue
        </button>
      <% } %>
    </div>
  </div>
  <div class="overflow-x-auto">
    <table id="club-venues-table" class="w-full text-sm">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Address</th>
          <th>Lat</th>
          <th>Lng</th>
          <th>Created</th>
          <% if (isOwner) { %>
            <th>Actions</th>
          <% } %>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>
</div>

<% if (isOwner) { %>
<!-- Add Venue Modal -->
<div id="add-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" >
  <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6" onclick="event.stopPropagation()">
    <h4 class="text-lg font-semibold mb-4">Add Venue</h4>
    <form id="add-form" autocomplete="off">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
        <input type="text" name="title" required autocomplete="off" placeholder="Enter venue title"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-sm" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Address <span class="text-red-500">*</span></label>
        <div class="autocomplete-wrapper">
          <input type="text" name="address" id="add-address" required autocomplete="off" placeholder="Start typing an address..."
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-sm" />
          <div id="add-dropdown" class="autocomplete-dropdown hidden"></div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Latitude</label>
          <input type="text" name="lat" id="add-lat" required readonly
            class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-sm text-gray-500" placeholder="Auto-filled" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Longitude</label>
          <input type="text" name="lng" id="add-lng" required readonly
            class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-sm text-gray-500" placeholder="Auto-filled" />
        </div>
      </div>
      <div class="flex gap-2 justify-end">
        <button type="button" onclick="document.getElementById('add-form').reset(); document.getElementById('add-modal').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100">Cancel</button>
        <button type="submit" id="add-btn" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90">Add Venue</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Venue Modal -->
<div id="edit-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" >
  <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6" onclick="event.stopPropagation()">
    <h4 class="text-lg font-semibold mb-4">Edit Venue</h4>
    <form id="edit-form" autocomplete="off">
      <input type="hidden" id="edit-id" />
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
        <input type="text" name="title" id="edit-title" autocomplete="off" placeholder="Enter venue title"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-sm" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
        <div class="autocomplete-wrapper">
          <input type="text" name="address" id="edit-address" autocomplete="off" placeholder="Start typing an address..."
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-sm" />
          <div id="edit-dropdown" class="autocomplete-dropdown hidden"></div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Latitude</label>
          <input type="text" name="lat" id="edit-lat" readonly
            class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-sm text-gray-500" placeholder="Auto-filled" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Longitude</label>
          <input type="text" name="lng" id="edit-lng" readonly
            class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-sm text-gray-500" placeholder="Auto-filled" />
        </div>
      </div>
      <div class="flex gap-2 justify-end">
        <button type="button" onclick="document.getElementById('edit-form').reset(); document.getElementById('edit-modal').classList.add('hidden')" class="px-4 py-2 border rounded-lg hover:bg-gray-100">Cancel</button>
        <button type="submit" id="edit-btn" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90">Update Venue</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<script>
  var isOwner = <%= isOwner ? 'true' : 'false' %>;
  var datatableUrl = isOwner ? '/admin/club/datatable' : '/admin/clubs/<%= clubAdmin.id %>/venues/datatable';

  // Address autocomplete (Nominatim)
  var acTimers = {};

  function setupAutocomplete(inputId, dropdownId, latId, lngId) {
    var input = document.getElementById(inputId);
    var dropdown = document.getElementById(dropdownId);
    if (!input || !dropdown) return;

    input.addEventListener('input', function() {
      var query = this.value.trim();
      clearTimeout(acTimers[inputId]);

      if (query.length < 3) {
        dropdown.classList.add('hidden');
        dropdown.innerHTML = '';
        return;
      }

      acTimers[inputId] = setTimeout(function() {
        dropdown.innerHTML = '<div class="ac-loading">Searching...</div>';
        dropdown.classList.remove('hidden');

        fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(query) + '&limit=5&addressdetails=1', {
          headers: { 'Accept-Language': 'en' }
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          dropdown.innerHTML = '';
          if (!data || data.length === 0) {
            dropdown.innerHTML = '<div class="ac-loading">No results found</div>';
            return;
          }
          data.forEach(function(place) {
            var item = document.createElement('div');
            item.className = 'ac-item';
            item.textContent = place.display_name;
            item.addEventListener('click', function() {
              input.value = place.display_name;
              document.getElementById(latId).value = place.lat;
              document.getElementById(lngId).value = place.lon;
              dropdown.classList.add('hidden');
              dropdown.innerHTML = '';
            });
            dropdown.appendChild(item);
          });
        })
        .catch(function() {
          dropdown.innerHTML = '<div class="ac-loading">Error fetching results</div>';
        });
      }, 300);
    });

    document.addEventListener('click', function(e) {
      if (!input.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.add('hidden');
      }
    });
  }

  if (isOwner) {
    setupAutocomplete('add-address', 'add-dropdown', 'add-lat', 'add-lng');
    setupAutocomplete('edit-address', 'edit-dropdown', 'edit-lat', 'edit-lng');
  }

  var clubVenuesTable;
  $(document).ready(function() {
    var columns = [
      { data: 'id' },
      { data: 'title' },
      {
        data: 'address',
        orderable: false,
        render: function(data) {
          var short = data && data.length > 50 ? data.substring(0, 50) + '...' : data;
          return '<span title="' + (data || '').replace(/"/g, '&quot;') + '">' + (short || '-') + '</span>';
        }
      },
      { data: 'lat', orderable: false },
      { data: 'lng', orderable: false },
      {
        data: 'createdAt',
        render: function(data) {
          return window.formatDateDMY(data);
        }
      }
    ];

    if (isOwner) {
      columns.push({
        data: null,
        orderable: false,
        searchable: false,
        render: function(data, type, row) {
          return '<div class="flex gap-2">' +
            '<button type="button" onclick=\'editClubVenue(' + JSON.stringify({id: row.id, title: row.title, address: row.address, lat: row.lat, lng: row.lng}) + ')\' class="px-3 py-1.5 bg-primary/10 text-primary rounded-md hover:bg-primary hover:text-white transition-colors text-xs font-medium">Edit</button>' +
            '<button type="button" onclick="deleteClubVenue(' + row.id + ')" class="px-3 py-1.5 bg-red-100 text-red-600 rounded-md hover:bg-red-600 hover:text-white transition-colors text-xs font-medium">Delete</button>' +
            '</div>';
        }
      });
    }

    clubVenuesTable = $('#club-venues-table').DataTable({
      processing: true,
      serverSide: true,
      ajax: datatableUrl,
      order: [[5, 'desc']],
      pageLength: 10,
      columns: columns,
      language: {
        processing: '<div class="flex items-center gap-2 text-gray-500"><svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Loading...</div>',
        emptyTable: 'No venues found',
        zeroRecords: 'No matching venues found'
      }
    });

    if (isOwner) {
      // Add Venue AJAX
      document.getElementById('add-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = document.getElementById('add-btn');
        var formData = new FormData(this);
        var body = {};
        formData.forEach(function(val, key) {
          body[key] = val;
        });
        window.showBtnLoader(btn);
        fetch('/admin/club', {
          method: 'POST',
          body: JSON.stringify(body),
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          window.hideBtnLoader(btn);
          if (data.success) {
            document.getElementById('add-modal').classList.add('hidden');
            document.getElementById('add-form').reset();
            window.ajaxSuccess(data.message, clubVenuesTable);
          } else {
            window.ajaxError(data.message);
          }
        })
        .catch(function() {
          window.hideBtnLoader(btn);
          window.ajaxError('Something went wrong');
        });
      });

      // Edit Venue AJAX
      document.getElementById('edit-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var btn = document.getElementById('edit-btn');
        var id = document.getElementById('edit-id').value;
        var formData = new FormData(this);
        var body = {};
        formData.forEach(function(val, key) {
          if (key !== 'edit-id') {
            body[key] = val;
          }
        });
        window.showBtnLoader(btn);
        fetch('/admin/club/' + id, {
          method: 'POST',
          body: JSON.stringify(body),
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          window.hideBtnLoader(btn);
          if (data.success) {
            document.getElementById('edit-modal').classList.add('hidden');
            window.ajaxSuccess(data.message, clubVenuesTable);
          } else {
            window.ajaxError(data.message);
          }
        })
        .catch(function() {
          window.hideBtnLoader(btn);
          window.ajaxError('Something went wrong');
        });
      });
    }
  });

  function editClubVenue(venue) {
    document.getElementById('edit-id').value = venue.id;
    document.getElementById('edit-title').value = venue.title || '';
    document.getElementById('edit-address').value = venue.address || '';
    document.getElementById('edit-lat').value = venue.lat || '';
    document.getElementById('edit-lng').value = venue.lng || '';
    document.getElementById('edit-modal').classList.remove('hidden');
  }

  function deleteClubVenue(id) {
    window.ajaxDelete('/admin/club/' + id + '/delete', 'Delete Venue?', 'This venue will be soft deleted.', clubVenuesTable);
  }
</script>
