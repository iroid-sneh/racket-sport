  // Add a new empty slot card
  function svcAddSlotCard() {
    if (!svcCourtsForSport().length) {
      window.adminToast('No courts exist for this sport. Please create a court first.', 'warning');
      return;
    }
    var list = document.getElementById('svc-slots-list');
    if (!list) return;
    // Accordion: collapse any currently-open duration card before adding a new one.
    list.querySelectorAll('.svc-card .svc-card-body.svc-expandable').forEach(function(b) {
      b.classList.add('svc-collapsed');
    });
    list.querySelectorAll('.svc-card .svc-chevron-icon').forEach(function(c) {
      c.classList.add('collapsed');
    });
    var card = svcBuildSlotCard(null);
    // New card opens expanded so admin can fill it in immediately.
    var newBody = card.querySelector('.svc-card-body.svc-expandable');
    if (newBody) newBody.classList.remove('svc-collapsed');
    var newChev = card.querySelector('.svc-chevron-icon');
    if (newChev) newChev.classList.remove('collapsed');
    list.appendChild(card);
    svcUpdateAddDurBtn();
  }

  // Delete slot card (with API call if it has an id)
  async function svcDeleteSlotCard(btn) {
    var card = btn.closest('.svc-card');
    var slotId = card && card.dataset.slotId;
    if (slotId) {
      var confirmed = await Swal.fire(Object.assign({}, window.swalTheme || {}, {
        icon: 'warning', title: 'Delete this duration?', text: 'This cannot be undone.',
        showCancelButton: true, confirmButtonText: 'Delete', confirmButtonColor: '#DC2626',
      }));
      if (!confirmed.isConfirmed) return;
      try {
        var r = await fetch('/admin/settings/services/bookings/slot/' + slotId + '/delete', { method: 'POST' });
        var j = await r.json();
        if (!j.success) { window.adminToast(j.message || 'Delete failed', 'error'); return; }
      } catch (e) { window.adminToast('Network error', 'error'); return; }
    }
    card.remove();
    svcUpdateAddDurBtn();
    window.adminToast('Duration removed', 'success');
  }

  // Per-court toggle handler inside a slot card
  function svcTogglePerCourt(chk) {
    var section = chk.closest('.svc-section-val');
    var baseWrap = section.querySelector('.svc-base-price-wrap');
    var perWrap  = section.querySelector('.svc-per-court-prices');
    if (baseWrap) baseWrap.style.display = chk.checked ? 'none' : '';
    if (perWrap)  perWrap.style.display  = chk.checked ? '' : 'none';
  }

  // Update card header label when duration dropdown changes
  function svcUpdateDurLabel(sel) {
    var card = sel.closest('.svc-card');
    var lbl = card && card.querySelector('.svc-dur-label');
    if (lbl) lbl.textContent = sel.value + ' minutes';
  }

  /* Condition card: collapse/expand — accordion within the slot. */
  function svcToggleCond(e, hdr) {
    var card = hdr.closest('.svc-cond-card');
    var body = card && card.querySelector('.svc-cond-body');
    var chev = hdr && hdr.querySelector('.svc-cond-chevron');
    if (!body) return;
    var slotCard = hdr.closest('.svc-card');
    var willHide = !body.classList.contains('svc-hidden');
    if (!willHide && slotCard) {
      // Expanding this condition — close any other open conditions in the same slot first.
      slotCard.querySelectorAll('.svc-conds-list .svc-cond-card').forEach(function(other) {
        var b = other.querySelector('.svc-cond-body');
        if (!b || b === body) return;
        if (!b.classList.contains('svc-hidden')) {
          b.classList.add('svc-hidden');
          var oc = other.querySelector('.svc-cond-chevron');
          if (oc) { oc.classList.add('closed'); oc.classList.remove('open'); }
        }
      });
    }
    body.classList.toggle('svc-hidden', willHide);
    if (chev) { chev.classList.toggle('open', !willHide); chev.classList.toggle('closed', willHide); }
    svcUpdateAddCondBtn(slotCard);
  }

  /* Applies to: days / date range */
  function svcAppliesTo(btn, mode) {
    var card = btn.closest('.svc-cond-card');
    card.querySelectorAll('.svc-apply-btn').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    card.querySelector('.svc-days-row-wrap').classList.toggle('svc-hidden', mode !== 'days');
    card.querySelector('.svc-dates-row-wrap').classList.toggle('svc-hidden', mode !== 'dates');
  }

  /* Court badge: select a court in condition */
  function svcCourtBadge(sel) {
    var val = sel.value;
    if (!val) return;
    var label = sel.options[sel.selectedIndex].dataset.label || sel.options[sel.selectedIndex].text;
    var row = sel.closest('.svc-cond-fld-col').querySelector('.svc-badges-row');
    if (row.querySelector('[data-cid="' + val + '"]')) { sel.value = ''; return; }
    var b = document.createElement('span');
    b.className = 'svc-court-badge';
    b.dataset.cid = val;
    b.textContent = label;
    b.title = 'Click to remove';
    b.onclick = function(){ b.remove(); };
    row.appendChild(b);
    sel.value = '';
  }

  /* Add a new empty condition card to a slot */
  function svcAddCondToSlot(btn) {
    if (!svcCourtsForSport().length) {
      window.adminToast('No courts exist for this sport. Please create a court first.', 'warning');
      return;
    }
    var slotCard = btn.closest('.svc-card');
    var condsList = btn.closest('.svc-cond-section').querySelector('.svc-conds-list');
    // Accordion: collapse any currently-open condition in this slot.
    condsList.querySelectorAll('.svc-cond-body').forEach(function(b) { b.classList.add('svc-hidden'); });
    condsList.querySelectorAll('.svc-cond-chevron').forEach(function(c) {
      c.classList.add('closed'); c.classList.remove('open');
    });
    var div = document.createElement('div');
    div.innerHTML = svcBuildCondHtml(null);
    var newCard = div.firstChild;
    // Open the newly-added condition so admin can fill it in immediately.
    var newBody = newCard.querySelector('.svc-cond-body');
    if (newBody) newBody.classList.remove('svc-hidden');
    var newChev = newCard.querySelector('.svc-cond-chevron');
    if (newChev) { newChev.classList.add('open'); newChev.classList.remove('closed'); }
    condsList.appendChild(newCard);
    svcUpdateAddCondBtn(slotCard);
  }

  /* Collect all slot data from DOM and POST to server */
  async function svcSaveAllSlots() {
    if (!SVC_VENUE_ID || !SVC_ACTIVE_SPORT) { window.adminToast('No venue or sport selected', 'error'); return; }
    var list = document.getElementById('svc-slots-list');
    if (!list) return;
    var cards = list.querySelectorAll('.svc-card');
    var slots = [];

    cards.forEach(function(card) {
      var slotId = card.dataset.slotId ? parseInt(card.dataset.slotId, 10) : null;
      var durSel = card.querySelector('.svc-dur-select');
      var durMins = durSel ? parseInt(durSel.value, 10) : 60;
      var toggle = card.querySelector('.svc-per-court-toggle');
      var usePerCourt = toggle ? toggle.checked : false;
      var baseInput = card.querySelector('.svc-base-price');
      var basePrice = baseInput ? parseFloat(baseInput.value) || 0 : 0;

      // Per-court prices
      var courtPrices = [];
      card.querySelectorAll('.svc-per-court-prices .svc-court-row').forEach(function(row) {
        var cid = parseInt(row.dataset.courtId, 10);
        var pInput = row.querySelector('.svc-court-price-val');
        var price = pInput ? parseFloat(pInput.value) || 0 : 0;
        if (cid) courtPrices.push({ court_id: cid, price: price });
      });

      // Conditions
      var conditions = [];
      card.querySelectorAll('.svc-conds-list .svc-cond-card').forEach(function(cc) {
        var nameEl = cc.querySelector('.svc-cond-name');
        var priceEl = cc.querySelector('.svc-cond-price');
        var startEl = cc.querySelector('.svc-cond-start');
        var endEl   = cc.querySelector('.svc-cond-end');
        var activeBtn = cc.querySelector('.svc-apply-btn.active');
        var condType = activeBtn && activeBtn.textContent.trim().toLowerCase().includes('date') ? 'dates' : 'days';

        var courtIds = [];
        cc.querySelectorAll('.svc-badges-row .svc-court-badge').forEach(function(badge) {
          var cid = parseInt(badge.dataset.cid, 10);
          if (cid) courtIds.push(cid);
        });

        var daysOfWeek = [];
        cc.querySelectorAll('.svc-day.on').forEach(function(d){ daysOfWeek.push(parseInt(d.dataset.day, 10)); });

        var dateFrom = cc.querySelector('.svc-cond-datefrom');
        var dateTo   = cc.querySelector('.svc-cond-dateto');

        conditions.push({
          name: nameEl ? nameEl.value : '',
          court_ids: courtIds,
          override_price: priceEl ? parseFloat(priceEl.value) || 0 : 0,
          start_time: startEl ? startEl.value : null,
          end_time: endEl ? endEl.value : null,
          condition_type: condType,
          days_of_week: condType === 'days' ? daysOfWeek : [],
          date_from: condType === 'dates' && dateFrom ? dateFrom.value : null,
          date_to: condType === 'dates' && dateTo ? dateTo.value : null,
        });
      });

      var slotObj = { duration_minutes: durMins, use_per_court_price: usePerCourt, base_price: basePrice, court_prices: courtPrices, conditions: conditions };
      if (slotId) slotObj.id = slotId;
      slots.push(slotObj);
    });

    // Validate all price fields > 0 before sending
    for (var _si = 0; _si < slots.length; _si++) {
      var _s = slots[_si];
      if (!_s.use_per_court_price) {
        if (!_s.base_price || _s.base_price <= 0) {
          window.adminToast('Price per court must be greater than 0', 'error'); return;
        }
      } else {
        for (var _ci = 0; _ci < _s.court_prices.length; _ci++) {
          if (!_s.court_prices[_ci].price || _s.court_prices[_ci].price <= 0) {
            window.adminToast('Each court price must be greater than 0', 'error'); return;
          }
        }
      }
      for (var _ki = 0; _ki < _s.conditions.length; _ki++) {
        var _cond = _s.conditions[_ki];
        if (!_cond.court_ids || !_cond.court_ids.length) {
          window.adminToast('Please select at least one court for pricing condition "' + (_cond.name || 'Condition ' + (_ki + 1)) + '"', 'error'); return;
        }
        if (!_cond.override_price || _cond.override_price <= 0) {
          window.adminToast('Pricing condition price must be greater than 0', 'error'); return;
        }
      }
    }

    // BG_02: end date must be after start date in date-range conditions
    // BG_03: no duplicate overlapping conditions (same court + time + period)
    var _toMins = function(t) { if (!t) return null; var p = t.split(':'); return +p[0] * 60 + (+p[1] || 0); };
    for (var _bi = 0; _bi < slots.length; _bi++) {
      var _bconds = slots[_bi].conditions;
      for (var _bj = 0; _bj < _bconds.length; _bj++) {
        var _ca = _bconds[_bj];
        // BG_02
        if (_ca.condition_type === 'dates') {
          if (!_ca.date_from || !_ca.date_to) {
            window.adminToast('Please enter both start and end dates for condition "' + (_ca.name || 'Condition ' + (_bj + 1)) + '"', 'error'); return;
          }
          if (_ca.date_from >= _ca.date_to) {
            window.adminToast('End date must be after start date in condition "' + (_ca.name || 'Condition ' + (_bj + 1)) + '"', 'error'); return;
          }
        }
        // BG_03: compare against every later condition in same slot
        for (var _bk = _bj + 1; _bk < _bconds.length; _bk++) {
          var _cb = _bconds[_bk];
          var _courtOvlp = _ca.court_ids.some(function(id) { return _cb.court_ids.indexOf(id) !== -1; });
          if (!_courtOvlp) continue;
          var _ts1 = _toMins(_ca.start_time), _te1 = _toMins(_ca.end_time);
          var _ts2 = _toMins(_cb.start_time), _te2 = _toMins(_cb.end_time);
          var _timeOvlp = _ts1 !== null && _te1 !== null && _ts2 !== null && _te2 !== null && _ts1 < _te2 && _ts2 < _te1;
          if (!_timeOvlp) continue;
          if (_ca.condition_type !== _cb.condition_type) continue;
          var _periodOvlp = false;
          if (_ca.condition_type === 'days') {
            _periodOvlp = _ca.days_of_week.some(function(d) { return _cb.days_of_week.indexOf(d) !== -1; });
          } else {
            _periodOvlp = _ca.date_from <= _cb.date_to && _cb.date_from <= _ca.date_to;
          }
          if (!_periodOvlp) continue;
          window.adminToast(
            'Duplicate overlapping conditions: "' + (_ca.name || 'Condition ' + (_bj + 1)) + '" and "' + (_cb.name || 'Condition ' + (_bk + 1)) + '" overlap on the same court and time period.',
            'error'
          );
          return;
        }
      }
    }

    window.showOverlay();
    try {
      var res = await fetch('/admin/settings/services/bookings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ venue_id: SVC_VENUE_ID, sport_type: SVC_ACTIVE_SPORT, slots: slots }),
      });
      var json = await res.json();
      if (!json.success) { window.adminToast(json.message || 'Save failed', 'error'); return; }
      Swal.fire(Object.assign({}, window.swalTheme, {
        icon: 'success', title: 'Saved!', text: 'Booking slots saved successfully.',
        timer: 1800, showConfirmButton: false,
      }));
      setTimeout(function(){ svcLoadSlots(SVC_ACTIVE_SPORT); }, 1800);
    } catch (e) {
      window.adminToast('Network error: ' + (e.message || 'Please try again.'), 'error');
    } finally {
      window.hideOverlay();
    }
  }

  async function svcSaveActivityTemplate(formEl, ev) {
    ev.preventDefault();
    var data = new FormData(formEl);
    var levelEnabled = data.get('level_restriction_enabled') === 'true';
    var body = {
      sport_type: parseInt(data.get('sport_type'), 10),
      name: data.get('name'),
      duration_minutes: parseInt(data.get('duration_minutes'), 10),
      min_capacity: parseInt(data.get('min_capacity'), 10),
      max_capacity: parseInt(data.get('max_capacity'), 10),
      price_per_player: parseFloat(data.get('price_per_player')),
      level_restriction_enabled: levelEnabled,
    };
    if (levelEnabled) {
      var lo = parseInt(data.get('min_required_level'), 10);
      var hi = parseInt(data.get('max_required_level'), 10);
      if (lo > hi) { var t = lo; lo = hi; hi = t; }
      body.min_required_level = lo;
      body.max_required_level = hi;
    }

    if (!body.price_per_player || body.price_per_player <= 0) {
      window.adminToast('Price per player must be greater than 0', 'error'); return;
    }

    var id = formEl.dataset.id;
    var url = (id && id !== 'new')
      ? '/admin/settings/services/activity-template/' + id
      : '/admin/settings/services/activity-template';
    var submitBtn = formEl.querySelector('button[type="submit"]');
    window.showBtnLoader(submitBtn);
    try {
      var res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (!json.success) {
        window.adminToast(json.message || 'Save failed', 'error');
        return false;
      }
      Swal.fire(Object.assign({}, window.swalTheme, {
        icon: 'success', title: 'Saved!', text: id && id !== 'new' ? 'Activity updated successfully.' : 'Activity created successfully.',
        timer: 1800, showConfirmButton: false,
      }));
      setTimeout(function() { location.reload(); }, 1800);
    } catch (e) {
      window.adminToast('Network error: ' + (e.message || 'Please try again.'), 'error');
    } finally {
      window.hideBtnLoader(submitBtn);
    }
    return false;
  }

  // Show / hide the level range slider when its toggle flips
  function svcToggleLevelSlider(checkbox) {
    var form = checkbox.closest('form');
    if (!form) return;
    var wrap = form.querySelector('[data-toggle-target]');
    if (!wrap) return;
    wrap.classList.toggle('svc-hidden', !checkbox.checked);
    if (checkbox.checked) {
      var slider = wrap.querySelector('.dual-slider');
      if (slider) svcRefreshDualSlider(slider);
    }
  }

  // Update the fill bar between the two thumbs of a dual range slider
  function svcRefreshDualSlider(slider) {
    var minEl = slider.querySelector('.dual-min');
    var maxEl = slider.querySelector('.dual-max');
    var fill = slider.querySelector('.dual-slider-fill');
    if (!minEl || !maxEl || !fill) return;
    var lo = parseInt(minEl.value, 10);
    var hi = parseInt(maxEl.value, 10);
    if (lo > hi) {
      // Visually we still show fill from the smaller value to the larger one;
      // form submit handler also normalises before sending.
      var t = lo; lo = hi; hi = t;
    }
    var loPct = ((lo - 1) / 4) * 100;
    var hiPct = ((hi - 1) / 4) * 100;
    fill.style.left = loPct + '%';
    fill.style.right = (100 - hiPct) + '%';
  }

  // Wire up all dual sliders on the page (initial render + after Add Activity inserts a card)
  function svcInitDualSliders(scope) {
    (scope || document).querySelectorAll('.dual-slider').forEach(function(slider) {
      if (slider.dataset.dualInit === '1') return;
      slider.dataset.dualInit = '1';
      var minEl = slider.querySelector('.dual-min');
      var maxEl = slider.querySelector('.dual-max');
      var refresh = function() { svcRefreshDualSlider(slider); };
      if (minEl) minEl.addEventListener('input', refresh);
      if (maxEl) maxEl.addEventListener('input', refresh);
      refresh();
    });
  }
  document.addEventListener('DOMContentLoaded', function() { svcInitDualSliders(); });

  async function svcDeleteActivityTemplate(id, ev) {
    ev.stopPropagation();
    var confirmed = await Swal.fire(Object.assign({}, window.swalTheme || {}, {
      icon: 'warning',
      title: 'Delete this activity template?',
      text: 'This action cannot be undone.',
      showCancelButton: true,
      confirmButtonText: 'Delete',
      cancelButtonText: 'Cancel',
      confirmButtonColor: '#DC2626',
    }));
    if (!confirmed.isConfirmed) return;
    try {
      var res = await fetch('/admin/settings/services/activity-template/' + id + '/delete', { method: 'POST' });
      var json = await res.json();
      if (!json.success) {
        window.adminToast(json.message || 'Delete failed', 'error');
        return;
      }
      window.adminToast('Activity deleted', 'success');
      setTimeout(function() { location.reload(); }, 900);
    } catch (e) {
      window.adminToast('Network error: ' + (e.message || 'Please try again.'), 'error');
    }
  }

  function svcAddActivityTemplate(sportId) {
    var pane = document.querySelector('.svc-activities-pane[data-sport-pane="' + sportId + '"]');
    if (!pane) return;
    var list = pane.querySelector('.svc-activities-list');
    var addBtn = pane.querySelector('.svc-add-btn-full');

    // Only allow one unsaved new card at a time — scroll to existing one if present.
    var existingNew = list.querySelector('.svc-activity-card[data-id="new"]');
    if (existingNew) { existingNew.scrollIntoView({ behavior: 'smooth', block: 'center' }); return; }

    var card = document.createElement('div');
    card.className = 'svc-card svc-activity-card';
    card.dataset.id = 'new';
    card.innerHTML = ''
      + '<div class="svc-card-header" onclick="svcToggleCard(this)">'
      + '  <span class="svc-card-title">New activity</span>'
      + '  <div class="svc-card-header-actions">'
      + '    <button type="button" class="svc-trash-btn" title="Cancel" onclick="svcCancelNewCard(event, this)">'
      + '      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M6 18L18 6M6 6l12 12"/></svg>'
      + '    </button>'
      + '    <span class="svc-arrow open"><svg fill="none" stroke="#8D99AE" viewBox="0 0 24 24" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></span>'
      + '  </div>'
      + '</div>'
      + '<div class="svc-card-body svc-expandable">'
      + '  <form class="svc-activity-form" data-id="new" onsubmit="return svcSaveActivityTemplate(this, event)">'
      + '    <input type="hidden" name="sport_type" value="' + sportId + '" />'

      + '    <div class="svc-fld">'
      + '      <div class="svc-fld-label"><strong>Name</strong><span class="svc-caption">Activity display name</span></div>'
      + '      <div class="svc-fld-control"><input class="svc-input" type="text" name="name" required /></div>'
      + '    </div>'

      + '    <div class="svc-fld">'
      + '      <div class="svc-fld-label"><strong>Duration</strong><span class="svc-caption">Fixed length players book for</span></div>'
      + '      <div class="svc-fld-control">'
      + '        <select class="svc-select svc-fld-select" name="duration_minutes" required>'
      + '          <option value="60" selected>60 minutes</option>'
      + '          <option value="90">90 minutes</option>'
      + '          <option value="120">120 minutes</option>'
      + '          <option value="180">180 minutes</option>'
      + '        </select>'
      + '      </div>'
      + '    </div>'

      + '    <div class="svc-fld">'
      + '      <div class="svc-fld-label"><strong>Capacity</strong><span class="svc-caption">Min / Max participants</span></div>'
      + '      <div class="svc-fld-control svc-cap-row">'
      + '        <input class="svc-input svc-num-sm" type="number" name="min_capacity" min="1" max="100" value="2" required />'
      + '        <span class="svc-mute">to</span>'
      + '        <input class="svc-input svc-num-sm" type="number" name="max_capacity" min="1" max="100" value="12" required />'
      + '        <span class="svc-mute">players</span>'
      + '      </div>'
      + '    </div>'

      + '    <div class="svc-fld">'
      + '      <div class="svc-fld-label"><strong>Price per player</strong></div>'
      + '      <div class="svc-fld-control">'
      + '        <div class="svc-price-input">'
      + '          <span class="svc-price-prefix">&pound;</span>'
      + '          <input class="svc-input svc-price-input-field" type="number" step="0.01" min="0.01" name="price_per_player" value="0" required />'
      + '        </div>'
      + '      </div>'
      + '    </div>'

      + '    <div class="svc-fld svc-fld-toggle">'
      + '      <div class="svc-fld-label"><strong>Level of Restriciton</strong><span class="svc-caption">Restrict to players of a certain level</span></div>'
      + '      <div class="svc-fld-control svc-fld-control-end">'
      + '        <label class="svc-toggle"><input type="checkbox" name="level_restriction_enabled" value="true" onchange="svcToggleLevelSlider(this)" /><span class="svc-toggle-track"></span></label>'
      + '      </div>'
      + '    </div>'

      + '    <div class="svc-level-slider-wrap svc-hidden" data-toggle-target>'
      + '      <div class="dual-slider">'
      + '        <div class="dual-slider-rail"></div>'
      + '        <div class="dual-slider-fill"></div>'
      + '        <input type="range" class="dual-min" name="min_required_level" min="1" max="5" step="1" value="1" />'
      + '        <input type="range" class="dual-max" name="max_required_level" min="1" max="5" step="1" value="5" />'
      + '      </div>'
      + '      <div class="dual-slider-ticks">'
      + '        <span><strong>1</strong><span>Beginner</span></span>'
      + '        <span><strong>2</strong><span>Improver</span></span>'
      + '        <span><strong>3</strong><span>Intermediate</span></span>'
      + '        <span><strong>4</strong><span>Advanced</span></span>'
      + '        <span><strong>5</strong><span>Expert</span></span>'
      + '      </div>'
      + '    </div>'

      + '    <div class="svc-card-footer"><button type="submit" class="svc-save-btn">Save</button></div>'
      + '  </form>'
      + '</div>';

    list.appendChild(card);

    // New card opens by default — set arrow rotation and reveal body.
    var arrow = card.querySelector('.svc-arrow');
    var body = card.querySelector('.svc-expandable');
    if (arrow) arrow.classList.add('open');
    if (body) body.classList.remove('svc-hidden');

    // Wire the dual slider for this newly-inserted card
    svcInitDualSliders(card);

    // Disable the "+ Add Activity" button so only one unsaved card can exist.
    if (addBtn) { addBtn.disabled = true; addBtn.classList.add('svc-add-btn-full--disabled'); }

    // Focus the name input for immediate typing
    var nameInput = card.querySelector('input[name="name"]');
    if (nameInput) nameInput.focus();
  }

  // Remove an unsaved new card and re-enable its pane's "+ Add Activity" button.
  function svcCancelNewCard(ev, btn) {
    ev.stopPropagation();
    var card = btn.closest('.svc-activity-card');
    if (!card || card.dataset.id !== 'new') return;
    var pane = card.closest('.svc-activities-pane');
    card.remove();
    if (pane) {
      var addBtn = pane.querySelector('.svc-add-btn-full');
      if (addBtn) { addBtn.disabled = false; addBtn.classList.remove('svc-add-btn-full--disabled'); }
    }
  }
</script>
