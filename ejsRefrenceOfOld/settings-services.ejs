  // Build a complete slot card DOM element
  function svcBuildSlotCard(slot) {
    var id = (slot && slot.id) || null;
    var durMins = (slot && slot.duration_minutes) || 60;
    var usePerCourt = !!(slot && slot.use_per_court_price);
    var basePrice = (slot && slot.base_price != null) ? slot.base_price : '0.00';
    var courtPrices = (slot && slot.courtPrices) || [];
    var conditions = (slot && slot.conditions) || [];

    var div = document.createElement('div');
    div.className = 'svc-card';
    if (id) div.dataset.slotId = id;

    var conditionsHtml = conditions.map(function(c){ return svcBuildCondHtml(c); }).join('');

    div.innerHTML = ''
      + '<div class="svc-card-hdr" onclick="svcToggleCard(this)">'
      + '<div class="svc-card-hdr-left">'
      + '<div class="svc-dur-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>'
      + '<span class="svc-card-title svc-dur-label">' + durMins + ' minutes</span>'
      + '</div>'
      + '<div class="svc-card-hdr-right">'
      + '<button type="button" class="svc-hdr-btn" onclick="event.stopPropagation();svcToggleCard(this.closest(\'.svc-card-hdr\'))">'
      + '<span class="svc-chevron-icon collapsed"><svg fill="none" stroke="#94A3B8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg></span>'
      + '</button>'
      + '<button type="button" class="svc-hdr-btn del" title="Delete duration" onclick="event.stopPropagation();svcDeleteSlotCard(this)">'
      + '<svg fill="none" stroke="#94A3B8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>'
      + '</button>'
      + '</div></div>'

      + '<div class="svc-card-body svc-expandable svc-collapsed">'

      // Duration select row
      + '<div class="svc-section">'
      + '<div class="svc-section-label"><strong>Duration</strong><span>Fixed length players book for</span></div>'
      + '<div class="svc-section-val"><div class="svc-dur-inline">'
      + '<select class="svc-input svc-dur-select" onchange="svcUpdateDurLabel(this)">'
      + [60,90,120,180].map(function(d){ return '<option value="' + d + '"' + (d == durMins ? ' selected' : '') + '>' + d + '</option>'; }).join('')
      + '</select>'
      + '<span style="font-size:13px;color:#94A3B8;">minutes</span>'
      + '</div></div></div>'

      // Price per court toggle row
      + '<div class="svc-section">'
      + '<div class="svc-section-label"><strong>Price per court</strong><span>Set individually per court</span></div>'
      + '<div class="svc-section-val">'
      + '<div class="svc-toggle-wrap">'
      + '<label class="svc-toggle"><input type="checkbox" class="svc-per-court-toggle"' + (usePerCourt ? ' checked' : '') + ' onchange="svcTogglePerCourt(this)" /><span class="svc-toggle-track"></span></label>'
      + '<span class="svc-toggle-label">Per court</span>'
      + '</div>'
      // Base price input (shown when toggle OFF)
      + '<div class="svc-base-price-wrap"' + (usePerCourt ? ' style="display:none"' : '') + '>'
      + '<div class="svc-price-field"><span class="svc-price-pfx">&pound;</span>'
      + '<input type="number" class="svc-input svc-price-in svc-base-price" value="' + basePrice + '" step="0.01" min="0.01" />'
      + '</div></div>'
      // Per-court prices (shown when toggle ON)
      + '<div class="svc-court-prices svc-per-court-prices"' + (!usePerCourt ? ' style="display:none"' : '') + '>'
      + svcCourtPriceRows(courtPrices)
      + '</div>'
      + '</div></div>'

      // Pricing conditions
      + '<div class="svc-cond-section">'
      + '<div class="svc-cond-section-hdr"><strong>Pricing conditions</strong><span>Override the base price for specific times, days, or dates.</span></div>'
      + '<div class="svc-conds-list">' + conditionsHtml + '</div>'
      + '<button type="button" class="svc-add-cond" onclick="svcAddCondToSlot(this)">'
      + '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>'
