<div class="rounded-xl shadow-md bg-white overflow-hidden">
  <div class="p-6 border-b border-gray-200">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <h3 class="text-lg font-semibold text-gray-800">Coaches List</h3>
      <a href="/admin/coaches/add" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 text-sm font-medium whitespace-nowrap">
        Add Coach
      </a>
    </div>
  </div>
  <div class="overflow-x-auto">
    <table id="coaches-table" class="w-full text-sm">
      <thead>
        <tr>
          <th>ID</th>
          <th>Image</th>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>
</div>

<script>
  var coachesTable, coachBaseUrl = '';
  $(document).ready(function() {
    coachesTable = $('#coaches-table').DataTable({
      processing: true,
      serverSide: true,
      ajax: {
        url: '/admin/coaches/datatable',
        dataSrc: function(json) {
          coachBaseUrl = json.baseUrl || '';
          return json.data;
        }
      },
      order: [[5, 'desc']],
      pageLength: 10,
      columns: [
        { data: 'id' },
        {
          data: 'image',
          orderable: false,
          searchable: false,
          render: function(data, type, row) {
            if (data) {
              return '<img src="' + coachBaseUrl + data + '" alt="' + row.name + '" class="w-10 h-10 rounded-full object-cover" onerror="this.outerHTML=\'<div class=\\\'w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-semibold text-sm\\\'>' + (row.name ? row.name.charAt(0).toUpperCase() : '?') + '</div>\'" />';
            }
            var initial = row.name ? row.name.charAt(0).toUpperCase() : '?';
            return '<div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-semibold text-sm">' + initial + '</div>';
          }
        },
        { data: 'name' },
        {
          data: 'email',
          render: function(data) {
            return data ? '<span class="text-gray-700">' + data + '</span>' : '<span class="text-gray-400">-</span>';
          }
        },
        {
          data: 'phone',
          orderable: true,
          render: function(data) {
            return data ? '<span class="text-gray-700">' + data + '</span>' : '<span class="text-gray-400">-</span>';
          }
        },
        {
          data: 'createdAt',
          render: function(data) {
            return window.formatDateDMY(data);
          }
        },
        {
          data: null,
          orderable: false,
          searchable: false,
          render: function(data, type, row) {
            return '<div class="flex gap-2">' +
              '<a href="/admin/coaches/' + row.id + '/edit" class="px-3 py-1.5 bg-primary/10 text-primary rounded-md hover:bg-primary hover:text-white transition-colors text-xs font-medium">Edit</a>' +
              '<button type="button" onclick="deleteCoach(' + row.id + ')" class="px-3 py-1.5 bg-red-100 text-red-600 rounded-md hover:bg-red-600 hover:text-white transition-colors text-xs font-medium">Delete</button>' +
              '</div>';
          }
        }
      ],
      language: {
        processing: '<div class="flex items-center gap-2 text-gray-500"><svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Loading...</div>',
        emptyTable: 'No coaches found',
        zeroRecords: 'No matching coaches found'
      }
    });
  });

  function deleteCoach(id) {
    window.ajaxDelete('/admin/coaches/' + id + '/delete', 'Delete Coach?', 'This coach will be soft deleted.', coachesTable);
  }
</script>
