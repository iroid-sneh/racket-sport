<!-- Back Button -->
<div class="mb-6">
  <a href="<%= basePath %>" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-primary transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Membership Plans
  </a>
</div>

<div class="rounded-xl shadow-md bg-white overflow-hidden">
  <div class="p-6 border-b border-gray-200">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <h3 class="text-lg font-semibold text-gray-800"><%= plan.name %></h3>
      <div class="flex gap-2">
        <a href="<%= basePath %>/<%= plan.id %>/edit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 text-sm font-medium">Edit</a>
        <% if (plan.is_active) { %>
          <span class="inline-flex items-center px-3 py-2 text-xs font-medium rounded-lg bg-green-100 text-green-700">Active</span>
        <% } else { %>
          <span class="inline-flex items-center px-3 py-2 text-xs font-medium rounded-lg bg-red-100 text-red-600">Inactive</span>
        <% } %>
      </div>
    </div>
  </div>

  <div class="p-6">
    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      <div class="bg-blue-50 rounded-lg p-4">
        <p class="text-xs text-blue-600 font-medium mb-1">Active Members</p>
        <p class="text-2xl font-bold text-blue-800"><%= activeUsersCount %></p>
      </div>
      <div class="bg-purple-50 rounded-lg p-4">
        <p class="text-xs text-purple-600 font-medium mb-1">Total Memberships (All Time)</p>
        <p class="text-2xl font-bold text-purple-800"><%= totalMemberships %></p>
      </div>
      <div class="bg-green-50 rounded-lg p-4">
        <p class="text-xs text-green-600 font-medium mb-1">Price</p>
        <p class="text-2xl font-bold text-green-800"><%= (parseFloat(plan.price) || 0).toFixed(2) %></p>
      </div>
    </div>

    <!-- Plan Details -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Plan Name</label>
          <p class="text-sm text-gray-800 font-medium"><%= plan.name %></p>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Duration</label>
          <p class="text-sm text-gray-800"><%= plan.duration_months %> month<%= plan.duration_months > 1 ? 's' : '' %></p>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Price</label>
          <p class="text-sm text-gray-800 font-medium text-green-700"><%= (parseFloat(plan.price) || 0).toFixed(2) %></p>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Discount Percentage</label>
          <p class="text-sm text-gray-800"><%= plan.discount_percentage || 0 %>%</p>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Early Access</label>
          <p class="text-sm text-gray-800"><%= plan.early_access_hours || 0 %> hours</p>
        </div>
      </div>

      <div class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Sport Access</label>
          <% var sportArr = plan.sport_access || []; %>
          <% var SPORT_IDS = { 1: 'Tennis', 2: 'Padel', 3: 'Pickleball' }; %>
          <% if (sportArr.length === 0) { %>
            <span class="inline-flex px-2 py-1 text-xs font-medium rounded bg-gray-100 text-gray-600">All Sports</span>
          <% } else { %>
            <div class="flex flex-wrap gap-2">
              <% sportArr.forEach(function(id) { %>
                <span class="inline-flex px-2 py-1 text-xs font-medium rounded bg-purple-100 text-purple-700"><%= SPORT_IDS[id] || id %></span>
              <% }); %>
            </div>
          <% } %>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Description</label>
          <p class="text-sm text-gray-800"><%= plan.description || '-' %></p>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Benefits</label>
          <p class="text-sm text-gray-800"><%= plan.benefits || '-' %></p>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Created</label>
          <p class="text-sm text-gray-800"><%= plan.createdAt ? new Date(plan.createdAt).toLocaleDateString('en-GB') : '-' %></p>
        </div>
      </div>
    </div>
  </div>
</div>
