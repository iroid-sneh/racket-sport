  // ===== Collect all discount data from a plan card =====
  function msCollectDiscounts(card) {
    var discounts = [];
    card.querySelectorAll('.ms-discount-card').forEach(function(dc) {
      var d = {};
      d.condition_name = dc.querySelector('[data-field="condition_name"]').value.trim();

      var dtGroup = dc.querySelector('[data-field="discount_type"]');
      var dtActive = dtGroup ? dtGroup.querySelector('.ms-btn-opt.active') : null;
      d.discount_type = dtActive ? dtActive.getAttribute('data-value') : 'percentage';

      d.discount_value = parseFloat(dc.querySelector('[data-field="discount_value"]').value) || 0;

      var appliesTo = [];
      dc.querySelectorAll('[data-field="applies_to"] .ms-applies-btn.active').forEach(function(b) {
        appliesTo.push(b.getAttribute('data-value'));
      });
      d.applies_to = appliesTo;

      var fcCb = dc.querySelector('[data-field="full_court_discount"]');
      d.full_court_discount = fcCb ? fcCb.checked : false;

      discounts.push(d);
    });
    return discounts;
  }

  // ===== Collect plan data from a card =====
  function msCollectPlanData(card) {
    var data = {};
    data.id = card.getAttribute('data-plan-id');
    data.name = card.querySelector('[data-field="name"]').value.trim();

    // Duration type
    var dtGroup = card.querySelector('[data-field="duration_type"]');
    var dtActive = dtGroup ? dtGroup.querySelector('.ms-btn-opt.active') : null;
    data.duration_type = dtActive ? dtActive.getAttribute('data-value') : 'fixed_length';

    data.duration_months = parseInt(card.querySelector('[data-field="duration_months"]').value) || 1;
    var endDateInput = card.querySelector('[data-field="end_date"]');
    data.end_date = endDateInput ? endDateInput.value : null;

    data.price = parseFloat(card.querySelector('[data-field="price"]').value) || 0;
    data.benefits = card.querySelector('[data-field="benefits"]').value.trim();
    data.advance_booking_days = parseInt(card.querySelector('[data-field="advance_booking_days"]').value) || 0;

    // Venues
    var venueIds = [];
    card.querySelectorAll('[data-field="venue_ids"] .ms-venue-chip.active').forEach(function(chip) {
      venueIds.push(parseInt(chip.getAttribute('data-venue-id')));
    });
    data.venue_ids = venueIds;

    // Discounts (multiple)
    data.discounts = msCollectDiscounts(card);

    return data;
  }

  // ===== Save All Plans =====
  function msSaveAll() {
    var saveBtn = document.getElementById('ms-save-all-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    var cards = document.querySelectorAll('#ms-plan-list .ms-card');

    // Step 1: Collect and validate all data BEFORE making any requests
    var planDataList = [];
    var hasEmptyName = false;

    cards.forEach(function(card) {
      var data = msCollectPlanData(card);
      if (!data.name) {
        hasEmptyName = true;
        card.querySelector('[data-field="name"]').style.borderBottomColor = '#EF4444';
        card.querySelector('[data-field="name"]').focus();
        return;
      }
      planDataList.push({ card: card, data: data });
    });

    if (hasEmptyName) {
      window.ajaxError('Please enter a name for all membership plans');
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
      return;
    }

    if (planDataList.length === 0) {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
      return;
    }

    // Step 2: Send requests only after all validation passes
    var promises = planDataList.map(function(item) {
      var card = item.card;
      var data = item.data;
      var planId = data.id;
      var isNew = !planId || planId === 'new';
      var url = isNew ? '/admin/settings/memberships' : '/admin/settings/memberships/' + planId;

      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) {
        if (!r.ok) {
          return r.text().then(function(text) {
            try { return JSON.parse(text); } catch(e) { return { success: false, message: 'Server error (' + r.status + ')' }; }
          });
        }
        return r.json();
      })
      .then(function(resp) {
        if (resp.success && isNew && resp.data && resp.data.id) {
          card.setAttribute('data-plan-id', resp.data.id);
        }
        return resp;
      });
    });

    Promise.all(promises)
      .then(function(results) {
        var allOk = results.every(function(r) { return r.success; });
        if (allOk) {
          window.ajaxSuccess('All membership plans saved successfully');
          setTimeout(function() { window.location.reload(); }, 1200);
        } else {
          var failed = results.filter(function(r) { return !r.success; });
          window.ajaxError(failed[0].message || 'Some plans failed to save');
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save Changes';
        }
      })
      .catch(function(err) {
        window.ajaxError(err.message || 'Something went wrong while saving');
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Changes';
      });
  }

  // ===== Delete Plan =====
  function msDeletePlan(planId, btn) {
    Swal.fire({
      title: 'Delete Membership?',
      text: 'Are you sure you want to delete this membership plan?',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#2B2D42',
      cancelButtonColor: '#6b7280',
      confirmButtonText: 'Yes, delete it'
    }).then(function(result) {
      if (!result.isConfirmed) return;

      var card = btn.closest('.ms-card');

      // If it's a new unsaved card, just remove from DOM
      if (!planId || planId === 'new') {
        card.remove();
        return;
      }

      fetch('/admin/settings/memberships/' + planId + '/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
      })
      .then(function(r) {
        if (!r.ok) {
          return r.text().then(function(text) {
            try { return JSON.parse(text); } catch(e) { return { success: false, message: 'Server error (' + r.status + ')' }; }
          });
        }
        return r.json();
      })
      .then(function(data) {
        if (data.success) {
          card.style.transition = 'opacity 0.3s, transform 0.3s';
          card.style.opacity = '0';
          card.style.transform = 'translateX(-20px)';
          setTimeout(function() { card.remove(); }, 300);
          window.ajaxSuccess('Membership plan deleted');
        } else {
          window.ajaxError(data.message || 'Failed to delete');
        }
      })
      .catch(function(err) { window.ajaxError(err.message || 'Something went wrong'); });
    });
  }

