                                            required />
                                        </div>
                                      </div>
                                      <div class="field-row">
                                        <div class="field-copy"><label class="field-label">Email</label></div>
                                        <div class="field-control field-control--input">
                                          <input type="email" name="email" class="field-input"
                                            value="<%= m.email || '' %>" required />
                                        </div>
