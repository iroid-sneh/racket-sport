                                          <button type="button" class="field-pill" data-sport-id="<%= s.id %>">
                                            <%= s.name %>
                                          </button>
                                          <% }); %>
                                      </div>
                                    </div>
                                  </div>

                                  <div class="field-row field-row--hours" id="add-hours-row" style="display:none;">
                                    <div class="field-copy">
                                      <label class="field-label">Available Days &amp; Hours</label>
                                      <p class="field-desc">Toggle each day on, then set the window.</p>
                                    </div>
                                    <div class="field-control" style="flex: 1;">
                                      <div class="avail-card" data-availability>
                                        <div class="avail-header">
                                          <span class="avail-header-title">Weekly schedule</span>
                                          <label class="avail-apply-line">
                                            <span>Apply same time to all days</span>
                                            <span class="field-toggle">
                                              <input type="checkbox" data-apply-all />
                                              <span class="field-toggle-slider"></span>
                                            </span>
                                          </label>
                                        </div>
                                        <div class="avail-grid">
                                          <% var addDayLabels=['', 'Monday' , 'Tuesday' , 'Wednesday' , 'Thursday'
                                            , 'Friday' , 'Saturday' , 'Sunday' ]; %>
                                            <% var addDefaultOn={ 1: true, 2: true, 3: true, 4: true, 5: true }; %>
                                              <% for (var d=1; d <=7; d++) { var on=!!addDefaultOn[d]; %>
                                                <div class="avail-row" data-day-row="<%= d %>">
                                                  <div class="avail-day-cell <%= on ? '' : 'disabled' %>">
                                                    <input type="checkbox" class="avail-check"
                                                      name="day_<%= d %>_enabled" value="true" <%=on ? 'checked' : '' %>
                                                    data-day-enable />
                                                    <span class="avail-day-label">
                                                      <%= addDayLabels[d] %>
                                                    </span>
                                                  </div>
                                                  <div class="avail-time-wrap">
                                                    <svg class="avail-time-icon" fill="none" stroke="currentColor"
                                                      viewBox="0 0 24 24">
                                                      <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="1.6"
                                                        d="M12 6v6l4 2m5-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                    </svg>
                                                    <input type="time" class="avail-time-input"
                                                      name="day_<%= d %>_start" value="<%= on ? '09:00' : '' %>" <%=on
                                                      ? '' : 'disabled' %> placeholder="Start Time" data-day-start />
                                                  </div>
                                                  <div class="avail-time-wrap">
                                                    <svg class="avail-time-icon" fill="none" stroke="currentColor"
                                                      viewBox="0 0 24 24">
                                                      <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="1.6"
                                                        d="M12 6v6l4 2m5-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                    </svg>
                                                    <input type="time" class="avail-time-input" name="day_<%= d %>_end"
                                                      value="<%= on ? '18:00' : '' %>" <%=on ? '' : 'disabled' %>
                                                    placeholder="End Time" data-day-end />
                                                  </div>
                                                </div>
                                                <% } %>
                                        </div>
                                      </div>
                                    </div>
                                  </div>

                                  <% var addPriceLabels=['Price for a player','Price for 2 player','Price for 3 player','Price for 4 player']; %>
                                  <div class="field-row field-row--prices" id="add-prices-row" style="display:none;">
                                    <div class="field-copy">
                                      <label class="field-label">Pricing variants</label>
                                      <p class="field-desc">Rates by duration and player count</p>
                                    </div>
                                    <div class="field-control" style="flex: 1;">
                                      <div class="price-list">
                                        <% for (var p=1; p <=4; p++) { %>
                                          <div class="price-row">
                                            <div class="price-input-wrap">
                                              <span class="price-currency">£</span>
                                              <input type="number" class="price-input"
                                                name="price_<%= p %>_player" min="0.01" step="0.01"
                                                placeholder="00.00" />
                                            </div>
                                            <span class="price-label"><%= addPriceLabels[p-1] %></span>
                                          </div>
                                        <% } %>
                                      </div>
                                    </div>
                                  </div>

                                  <div class="field-row field-row--photo" id="add-photo-row">
                                    <div class="field-copy">
                                      <label class="field-label">Profile picture</label>
                                      <p class="field-desc">Shown to players in the app</p>
                                    </div>
                                    <div class="field-control">
                                      <div class="field-photo-row">
                                        <div class="field-photo-preview" data-photo-preview>
                                          <svg width="18" height="18" fill="none" stroke="#9CA3AF" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"
                                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                          </svg>
                                        </div>
                                        <label class="field-photo-trigger" for="add-photo-input">
                                          <svg width="14" height="14" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"
                                              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                          </svg>
                                          Upload photo
                                        </label>
                                        <input type="file" id="add-photo-input" name="image_file" accept="image/*"
                                          class="field-photo-input" data-photo-input />
                                      </div>
                                    </div>
                                  </div>

                                  <div class="field-save-row">
                                    <button type="button" class="staff-save-btn staff-save-btn-secondary"
                                      onclick="closeAddForm()">Cancel</button>
                                    <button type="submit" class="staff-save-btn" id="add-submit-btn">Add</button>
                                  </div>
                                </form>
                              </div>
                            </div>

                            <% } %>

                  </div>
                </div>
              </div>
          </div>

          <script>
            // Top-level tabs (Manager | Team) — persisted in localStorage so the active tab
            // survives page reloads (after add/edit/delete) and navigation away & back.
            var STAFF_TAB_KEY = 'admin_settings_staff_tab';
            var defaultMainTab = '<%= canManageManagers ? "manager" : "team" %>';
            var currentMainTab = defaultMainTab;
            function setMainTab(tab, opts) {
              currentMainTab = tab;
              document.querySelectorAll('.staff-tab').forEach(function (b) {
                b.classList.toggle('active', b.dataset.mainTab === tab);
              });
              document.querySelectorAll('.main-tab-panel').forEach(function (p) {
                p.classList.toggle('staff-hidden', p.dataset.mainPanel !== tab);
              });
              closeAddForm(); // collapse any open add-form when switching
              if (!opts || !opts.silent) {
                try { localStorage.setItem(STAFF_TAB_KEY, tab); } catch (e) { }
              }
            }
            document.querySelectorAll('.staff-tab').forEach(function (btn) {
              btn.addEventListener('click', function () { setMainTab(this.dataset.mainTab); });
            });
            // Restore last active tab on initial load
            (function restoreStaffTab() {
              try {
                var saved = localStorage.getItem(STAFF_TAB_KEY);
                if (!saved) return;
                // Only honor a saved tab if its button is rendered (e.g. non-managers can't see "manager")
                var btn = document.querySelector('.staff-tab[data-main-tab="' + saved + '"]');
                if (btn && saved !== currentMainTab) setMainTab(saved, { silent: true });
              } catch (e) { }
            })();

            // ── Card expand/collapse ──
            function toggleCard(header) {
              var card = header.closest('.staff-card');
              var content = card.querySelector('.staff-expanded');
              var chevron = header.querySelector('.staff-chevron-btn');
              if (content.classList.contains('staff-hidden')) {
                content.classList.remove('staff-hidden');
                chevron.classList.remove('staff-chevron-collapsed');
                chevron.classList.add('staff-chevron-expanded');
              } else {
                content.classList.add('staff-hidden');
                chevron.classList.remove('staff-chevron-expanded');
                chevron.classList.add('staff-chevron-collapsed');
              }
            }

            // ── Add form ──
            // addContext = 'manager' | 'team'   addSubRole = 'coach' | 'staff' (team only)
            var addContext = 'manager';
            var addSubRole = 'coach';

            function syncAddSubRole() {
              var typeInput = document.getElementById('add-member-type');
              if (typeInput) typeInput.value = addSubRole === 'coach' ? '1' : '2';
              document.querySelectorAll('#add-role-tabs .field-pill').forEach(function (b) {
                b.classList.toggle('active', b.dataset.role === addSubRole);
              });
              // Coach-only fields visible only when team + coach
              var isCoach = (addContext === 'team' && addSubRole === 'coach');
              var sportsRow = document.getElementById('add-sports-row');
              var hoursRow = document.getElementById('add-hours-row');
              var pricesRow = document.getElementById('add-prices-row');
              if (sportsRow) sportsRow.style.display = isCoach ? 'grid' : 'none';
              if (hoursRow) hoursRow.style.display = isCoach ? 'grid' : 'none';
              if (pricesRow) pricesRow.style.display = isCoach ? 'grid' : 'none';
              // Required-on-coach toggle for the 4 price inputs
              if (pricesRow) {
                pricesRow.querySelectorAll('.price-input').forEach(function (inp) {
                  if (isCoach) inp.setAttribute('required', 'required');
                  else inp.removeAttribute('required');
                });
              }
            }

            function openAddForm(context) {
              addContext = context;
              var wrap = document.getElementById('add-form-wrapper');
              var roleRow = document.getElementById('add-role-row');
              var pwdRow = document.getElementById('add-password-row');
              var phoneRow = document.getElementById('add-phone-row');
              var photoRow = document.getElementById('add-photo-row');
              var emailInput = document.getElementById('add-email');
              var nameLabel = document.getElementById('add-name-label');

              document.getElementById('add-form').reset();
              document.querySelectorAll('#add-sport-group .field-pill.active').forEach(function (p) { p.classList.remove('active'); });
              var addPreview = document.querySelector('#add-photo-row [data-photo-preview]');
              if (addPreview) {
                addPreview.innerHTML = '<svg width="18" height="18" fill="none" stroke="#9CA3AF" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>';
              }

              if (context === 'manager') {
                roleRow.style.display = 'none';
                pwdRow.style.display = 'grid';
                phoneRow.style.display = 'none';
                photoRow.style.display = 'grid';
                emailInput.setAttribute('required', 'required');
                nameLabel.textContent = 'Full name';
                document.getElementById('add-sports-row').style.display = 'none';
                document.getElementById('add-hours-row').style.display = 'none';
                var addPricesRow = document.getElementById('add-prices-row');
                if (addPricesRow) {
                  addPricesRow.style.display = 'none';
                  addPricesRow.querySelectorAll('.price-input').forEach(function (inp) {
                    inp.removeAttribute('required');
                  });
                }
              } else {
                // team — default to Coach
                addSubRole = 'coach';
                roleRow.style.display = 'grid';
                pwdRow.style.display = 'none';
                phoneRow.style.display = 'grid';
                photoRow.style.display = 'grid';
                emailInput.removeAttribute('required');
                nameLabel.textContent = 'Name';
                syncAddSubRole();
              }

              wrap.classList.remove('staff-hidden');
              // Manual scroll on .staff-content-area only — using scrollIntoView would also
              // scroll every overflow:hidden ancestor (#admin-main, :root, etc.) programmatically,
              // and because they're overflow:hidden the user can't wheel them back.
              requestAnimationFrame(function () {
                var area = document.querySelector('.staff-content-area');
                if (!area) return;
                var areaRect = area.getBoundingClientRect();
                var wrapRect = wrap.getBoundingClientRect();
                area.scrollTo({
                  top: area.scrollTop + (wrapRect.top - areaRect.top),
                  behavior: 'smooth'
                });
              });
            }

            function closeAddForm() {
              var wrap = document.getElementById('add-form-wrapper');
              if (wrap) wrap.classList.add('staff-hidden');
              var form = document.getElementById('add-form');
              if (form) form.reset();
            }

            document.querySelectorAll('#add-role-tabs .field-pill').forEach(function (b) {
              b.addEventListener('click', function () {
                addSubRole = this.dataset.role === 'staff' ? 'staff' : 'coach';
                syncAddSubRole();
              });
            });

            // ── Coach fields: pill toggle + photo preview ──
            document.querySelectorAll('[data-sport-group]').forEach(function (group) {
              // Skip the add-role pill group which has its own handler above
              if (group.id === 'add-role-tabs') return;
              group.addEventListener('click', function (e) {
                var btn = e.target.closest('.field-pill');
                if (!btn) return;
                btn.classList.toggle('active');
              });
            });

            document.querySelectorAll('[data-photo-input]').forEach(function (input) {
              input.addEventListener('change', function () {
                var file = this.files && this.files[0];
                if (!file) return;
                var preview = this.closest('.field-photo-row').querySelector('[data-photo-preview]');
                if (!preview) return;
                var reader = new FileReader();
                reader.onload = function (evt) {
                  preview.innerHTML = '<img src="' + evt.target.result + '" alt="Preview" />';
                };
                reader.readAsDataURL(file);
              });
            });

            // ── Name validation (shared between add + edit forms) ──
            function validateNameValue(raw) {
              var trimmed = (raw || '').trim();
              if (trimmed === '') return 'Name is required';
              if (trimmed.length < 2) return 'Name must be at least 2 characters';
              if (trimmed.length > 100) return 'Name is too long';
              if (!/\p{L}/u.test(trimmed)) {
                return 'Name must contain letters, not only numbers or special characters';
              }
              if (!/^[\p{L}][\p{L}\s.''\-]*$/u.test(trimmed)) {
                return 'Name can only contain letters, spaces, hyphens, apostrophes and periods';
              }
              return null;
            }
            function checkNameInForm(form) {
              var nameInput = form.querySelector('input[name="name"]');
              // Coach edit forms send name via a hidden input — skip those.
              if (!nameInput || nameInput.type === 'hidden') return true;
              var err = validateNameValue(nameInput.value);
              if (err) {
                window.adminToast(err, 'error');
                nameInput.focus();
                return false;
              }
              return true;
            }

            // ── Phone validation (shared between add + edit forms) ──
            function validatePhoneValue(raw) {
              var trimmed = (raw || '').trim();
              if (trimmed === '') return null; // optional
              if (trimmed.length > 20) return 'Phone number is too long';
              if (!/^\+?[0-9\s\-()]+$/.test(trimmed)) {
                return 'Phone number can only contain digits and an optional leading +';
              }
              var digits = trimmed.replace(/[^0-9]/g, '');
              if (digits.length < 7 || digits.length > 15) {
                return 'Phone number must be between 7 and 15 digits';
              }
              if (/^0+$/.test(digits)) {
                return 'Phone number cannot consist entirely of zeros';
              }
              return null;
            }
            // Block invalid characters at typing time so users get instant feedback.
            document.addEventListener('input', function (e) {
              var input = e.target;
              if (!input || !input.matches || !input.matches('[data-phone-input]')) return;
              var cleaned = input.value.replace(/[^\d+\s\-()]/g, '');
              // Only one + and only at the start
              cleaned = cleaned.replace(/\+/g, function (_, idx, str) { return idx === 0 ? '+' : ''; });
              if (cleaned !== input.value) input.value = cleaned;
            });
            function checkPhoneInForm(form) {
              var phoneInput = form.querySelector('[data-phone-input]');
              if (!phoneInput || phoneInput.offsetParent === null) return true; // hidden = skip
              var err = validatePhoneValue(phoneInput.value);
              if (err) {
                window.adminToast(err, 'error');
                phoneInput.focus();
                return false;
              }
              return true;
            }

            // ── Add submit ──
            var addForm = document.getElementById('add-form');
            if (addForm) {
              addForm.addEventListener('submit', function (e) {
                e.preventDefault();
                if (!checkNameInForm(this)) return;
                if (!checkPhoneInForm(this)) return;
                var btn = document.getElementById('add-submit-btn');
                btn.disabled = true;
                var fd = new FormData(this);

                var url, imageField;
                if (addContext === 'manager') {
                  url = '/admin/settings/staff/manager';
                  imageField = 'manager_image';
                } else {
                  url = '/admin/settings/staff/member';
                  imageField = 'member_image';
                  // Harvest sport pills (only relevant when Coach)
                  document.querySelectorAll('#add-sport-group .field-pill.active').forEach(function (pill) {
                    fd.append('sport_type_ids[]', pill.dataset.sportId);
                  });
                }

                // Rename image field to match multer
                var fileInput = this.querySelector('#add-photo-input');
                fd.delete('image_file');
                if (fileInput && fileInput.files && fileInput.files[0]) {
                  fd.append(imageField, fileInput.files[0]);
                }

                fetch(url, { method: 'POST', body: fd, headers: { 'Accept': 'application/json' } })
                  .then(function (r) { return r.json(); })
                  .then(function (data) {
                    btn.disabled = false;
                    if (data.success) {
                      if (window.ajaxSuccess) window.ajaxSuccess(data.message);
                      setTimeout(function () { window.location.reload(); }, 600);
                    } else {
                      if (window.ajaxError) window.ajaxError(data.message);
                      else alert(data.message || 'Failed');
                    }
                  })
                  .catch(function () {
                    btn.disabled = false;
                    if (window.ajaxError) window.ajaxError('Something went wrong');
                    else alert('Something went wrong');
                  });
              });
            }

            // ── Per-card edit save ──
            document.querySelectorAll('.staff-edit-form').forEach(function (form) {
              form.addEventListener('submit', function (e) {
                e.preventDefault();
                if (!checkNameInForm(form)) return;
                if (!checkPhoneInForm(form)) return;
                var kind = form.dataset.kind;
                var id = form.dataset.id;
                var url = kind === 'manager'
                  ? '/admin/settings/staff/manager/' + id
                  : '/admin/settings/staff/member/' + id;
                var btn = form.querySelector('button[type="submit"]');
                btn.disabled = true;
                var fd = new FormData(form);

                // If this form has a sport pill group (Coach), harvest active pills.
                var pillGroup = form.querySelector('[data-sport-group]');
                if (pillGroup) {
                  pillGroup.querySelectorAll('.field-pill.active').forEach(function (pill) {
                    fd.append('sport_type_ids[]', pill.dataset.sportId);
                  });
                }

                fetch(url, { method: 'POST', body: fd, headers: { 'Accept': 'application/json' } })
                  .then(function (r) { return r.json(); })
                  .then(function (data) {
                    btn.disabled = false;
                    if (data.success) {
                      if (window.ajaxSuccess) window.ajaxSuccess(data.message);
                      setTimeout(function () { window.location.reload(); }, 600);
                    } else {
                      if (window.ajaxError) window.ajaxError(data.message);
                      else alert(data.message || 'Failed');
                    }
                  })
                  .catch(function () {
                    btn.disabled = false;
                    if (window.ajaxError) window.ajaxError('Something went wrong');
                    else alert('Something went wrong');
                  });
              });
            });

            // ── Availability card: enable/disable per day + apply-all sync ──
            function initAvailabilityCard(card) {
              if (!card) return;

              function setRowEnabled(row, enabled) {
                var cell = row.querySelector('.avail-day-cell');
                var startInput = row.querySelector('[data-day-start]');
                var endInput = row.querySelector('[data-day-end]');
                if (cell) cell.classList.toggle('disabled', !enabled);
                if (startInput) startInput.disabled = !enabled;
                if (endInput) endInput.disabled = !enabled;
              }

              card.querySelectorAll('[data-day-enable]').forEach(function (chk) {
                chk.addEventListener('change', function () {
                  var row = chk.closest('[data-day-row]');
                  setRowEnabled(row, chk.checked);
                });
              });

              var applyAll = card.querySelector('[data-apply-all]');
              var firstRow = card.querySelector('[data-day-row="1"]');
              if (applyAll && firstRow) {
                var firstStart = firstRow.querySelector('[data-day-start]');
                var firstEnd = firstRow.querySelector('[data-day-end]');

                function syncFromFirst() {
                  if (!applyAll.checked) return;
                  var s = firstStart ? firstStart.value : '';
                  var e = firstEnd ? firstEnd.value : '';
                  card.querySelectorAll('[data-day-row]').forEach(function (r) {
                    if (r === firstRow) return;
                    var rs = r.querySelector('[data-day-start]');
                    var re = r.querySelector('[data-day-end]');
                    if (rs && !rs.disabled) rs.value = s;
                    if (re && !re.disabled) re.value = e;
                  });
                }

                // When apply-all is ON, lock the time inputs on every non-first day so
                // the user can't override individual days. Inputs stay submittable
                // (readonly, not disabled) and stay synced with the first row.
                function lockNonFirstRows(locked) {
                  card.querySelectorAll('[data-day-row]').forEach(function (r) {
                    if (r === firstRow) return;
                    [r.querySelector('[data-day-start]'), r.querySelector('[data-day-end]')].forEach(function (inp) {
                      if (!inp) return;
                      if (locked) {
                        inp.setAttribute('readonly', 'readonly');
                        inp.classList.add('avail-time-locked');
                      } else {
                        inp.removeAttribute('readonly');
                        inp.classList.remove('avail-time-locked');
                      }
                    });
                  });
                }

                applyAll.addEventListener('change', function () {
                  lockNonFirstRows(applyAll.checked);
                  syncFromFirst();
                });
                if (firstStart) firstStart.addEventListener('input', syncFromFirst);
                if (firstEnd) firstEnd.addEventListener('input', syncFromFirst);

                // Initial state — handles the case where the checkbox is pre-checked.
                lockNonFirstRows(applyAll.checked);
              }
            }
            document.querySelectorAll('[data-availability]').forEach(initAvailabilityCard);

            // Venue change is handled centrally in layout.ejs (overlay + reload).

            // ── Delete ──
            function deleteRow(btn, kind) {
              var card = btn.closest('.staff-card');
              var id = card.dataset.id;
              var name = card.querySelector('.staff-card-name').textContent.trim();

              Swal.fire({
                title: 'Delete ' + name + '?',
                text: 'This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel',
                ...window.swalTheme
              }).then(function (result) {
                if (!result.isConfirmed) return;

                var url = kind === 'manager'
                  ? '/admin/settings/staff/manager/' + id + '/delete'
                  : '/admin/settings/staff/member/' + id + '/delete';

                window.showBtnLoader(btn);
                fetch(url, { method: 'POST', headers: { 'Accept': 'application/json' } })
                  .then(function (r) { return r.json(); })
                  .then(function (data) {
                    window.hideBtnLoader(btn);
                    if (data.success) {
                      window.ajaxSuccess(data.message);
                      setTimeout(function () { window.location.reload(); }, 400);
                    } else {
                      window.ajaxError(data.message);
                    }
                  })
                  .catch(function () {
                    window.hideBtnLoader(btn);
                    window.ajaxError('Something went wrong');
                  });
              });
            }
          </script>