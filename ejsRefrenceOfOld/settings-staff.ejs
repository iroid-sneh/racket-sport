<% var currentPage='settings-staff' ; %>

  <style>
    /* ── Settings sub-nav ── */
    .staff-settings-sidebar {
      width: 225px;
      background: #F8F9FB;
      padding: 16px 0;
      flex-shrink: 0;
    }

    .staff-settings-title {
      padding: 12px 16px 12px;
      border-bottom: 1px solid #E7EBEF;
      margin-bottom: 12px;
    }

    .staff-settings-title h2 {
      font-size: 14px;
      font-weight: 600;
      color: #0A0A0A;
      line-height: 20px;
    }

    .staff-settings-nav {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 0 16px;
    }

    .staff-settings-nav a {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 8px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 400;
      color: #737373;
      line-height: 20px;
      text-decoration: none;
      transition: background 0.15s;
    }

    .staff-settings-nav a:hover {
      background: rgba(141, 153, 174, 0.1);
    }

    .staff-settings-nav a.active {
      background: rgba(141, 153, 174, 0.2);
      color: #2B2D42;
    }

    .staff-settings-nav a svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    /* ── Header / breadcrumb ── */
    .staff-header {
      background: #FFFFFF;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 24px;
    }

    .staff-breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .staff-breadcrumb a {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: #8D99AE;
      text-decoration: none;
    }

    .staff-breadcrumb .sep {
      font-size: 12px;
      color: rgba(141, 153, 174, 0.4);
    }

    .staff-breadcrumb .current {
      font-size: 12px;
      font-weight: 600;
      color: #2B2D42;
    }

    /* ── Section title ── */
    .staff-section-header {
      background: #FFFFFF;
      padding: 16px 24px;
      border-top: 1px solid #E7EBEF;
    }

    .staff-section-header h1 {
      font-size: 16px;
      font-weight: 700;
      color: #2B2D42;
      line-height: 24px;
    }

    .staff-section-header p {
      font-size: 12px;
      font-weight: 400;
      color: #8D99AE;
      line-height: 16px;
      margin-top: 2px;
    }

    /* ── Tabs (top-level, Manager | Staff & Coach) ── */
    .staff-tabs-bar {
      background: #FFFFFF;
      padding: 0 24px;
      border-bottom: 1px solid #E7EBEF;
      display: flex;
      gap: 4px;
    }

    .staff-tab {
      padding: 10px 18px;
      font-size: 13px;
      font-weight: 500;
      color: #8D99AE;
      background: transparent;
      border: none;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
    }

    .staff-tab:hover {
      color: #2B2D42;
    }

    .staff-tab.active {
      color: #2B2D42;
      border-bottom-color: #2B2D42;
    }

    /* ── Content area ── */
    .staff-content-area {
      background: #F2F4F7;
      flex: 1;
      overflow-y: auto;
      min-height: 0;
    }

    .staff-content-inner {
      padding: 24px;
      max-width: 960px;
    }

    .staff-cards {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    /* ── Card ── */
    .staff-card {
      background: #FFFFFF;
      border: 1px solid #E7EBEF;
      border-radius: 8px;
      overflow: hidden;
    }

    .staff-card-header {
      display: flex;
      align-items: center;
      padding: 12px 16px;
      gap: 12px;
      cursor: pointer;
    }

    .staff-card-header:hover {
      background: rgba(141, 153, 174, 0.03);
    }

    .staff-chevron-btn {
      width: 24px;
      height: 24px;
      border-radius: 4px;
      border: none;
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      cursor: pointer;
      padding: 0;
    }

    .staff-chevron-btn svg {
      width: 14px;
      height: 14px;
      transition: transform 0.2s;
    }

    .staff-chevron-collapsed svg {
      transform: rotate(-90deg);
    }

    .staff-chevron-expanded svg {
      transform: rotate(0deg);
    }

    .staff-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 600;
      flex-shrink: 0;
      background: #E0E7FF;
      color: #4338CA;
      overflow: hidden;
    }

    .staff-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 50%;
    }

    .staff-card-info {
      flex: 1;
      min-width: 0;
    }

    .staff-card-name {
      font-size: 14px;
      font-weight: 500;
      color: #2B2D42;
      line-height: 20px;
    }

    .staff-card-email {
      font-size: 12px;
      font-weight: 400;
      color: #8D99AE;
      line-height: 16px;
    }

    .staff-badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 500;
      line-height: 18px;
      flex-shrink: 0;
    }

    .staff-badge-coach {
      background: #ECFDF5;
      color: #059669;
    }

    .staff-badge-manager {
      background: #EFF6FF;
      color: #2563EB;
    }

    .staff-badge-staff {
      background: #FEF3C7;
      color: #B45309;
    }

    .staff-delete-btn {
      width: 28px;
      height: 28px;
      border-radius: 4px;
      border: none;
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      padding: 0;
      color: #8D99AE;
    }

    .staff-delete-btn:hover {
      background: #FEE2E2;
      color: #DC2626;
    }

    .staff-delete-btn svg {
      width: 14px;
      height: 14px;
    }

    .staff-expanded {
      border-top: 1px solid #E7EBEF;
      padding: 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .staff-hidden {
      display: none !important;
    }

    .staff-form-row {
      display: grid;
      grid-template-columns: 150px minmax(0, 1fr);
      gap: 16px;
      align-items: flex-start;
    }

    .staff-form-label-col {
      padding-top: 8px;
    }

    .staff-form-label {
      font-size: 13px;
      font-weight: 500;
      color: #2B2D42;
      line-height: 20px;
    }

    .staff-form-field-col {
      flex: 1;
      min-width: 0;
    }

    .staff-input {
      width: 100%;
      height: 36px;
      padding: 0 12px;
      background: #FFFFFF;
      border: 1px solid #E7EBEF;
      border-radius: 6px;
      font-size: 13px;
      color: #2B2D42;
      line-height: 20px;
      outline: none;
      box-sizing: border-box;
    }

    .staff-input:focus {
      border-color: #2B2D42;
    }

    .staff-input::placeholder {
      color: #8D99AE;
    }

    .staff-caption {
      font-size: 11px;
      font-weight: 400;
      color: #8D99AE;
      line-height: 16px;
      margin-top: 4px;
    }

    .staff-role-tabs {
      display: flex;
      gap: 4px;
      background: #F2F4F7;
      border-radius: 6px;
      padding: 3px;
    }

    .staff-role-tab {
      padding: 4px 12px;
      border-radius: 4px;
      border: none;
      background: transparent;
      font-size: 12px;
      font-weight: 500;
      color: #8D99AE;
      cursor: pointer;
      line-height: 20px;
    }

    .staff-role-tab.active {
      background: #2B2D42;
      color: #FFFFFF;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
    }

    .staff-file-input {
      width: 100%;
      min-height: 36px;
      padding: 7px 10px;
      font-size: 12px;
      color: #2B2D42;
      border: 1px solid #E7EBEF;
      border-radius: 6px;
      background: #FFFFFF;
      box-sizing: border-box;
    }

    .staff-save-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 0 14px;
      height: 32px;
      background: #2B2D42;
      border-radius: 4px;
      border: none;
      font-size: 12px;
      font-weight: 500;
      color: #FFFFFF;
      cursor: pointer;
      white-space: nowrap;
    }

    .staff-save-btn:hover {
      background: #1a1b2e;
    }

    .staff-save-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .staff-save-btn-secondary {
      background: #FFFFFF;
      color: #2B2D42;
      border: 1px solid #E7EBEF;
      margin-right: 8px;
    }

    .staff-save-btn-secondary:hover {
      background: #F8F9FB;
    }

    .staff-actions-row {
      display: flex;
      justify-content: flex-end;
      padding-top: 8px;
      border-top: 1px solid #E7EBEF;
    }

    .staff-add-member-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      width: 100%;
      height: 40px;
      margin-top: 12px;
      background: #FFFFFF;
      border: 1px dashed #D1D5DB;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      color: #8D99AE;
      cursor: pointer;
      transition: all 0.15s;
    }

    .staff-add-member-btn:hover {
      background: #F8F9FB;
      border-color: #8D99AE;
      color: #2B2D42;
    }

    .staff-add-member-btn svg {
      width: 14px;
      height: 14px;
    }

    .staff-empty {
      padding: 16px;
      background: #F8F9FB;
      border: 1px dashed #E7EBEF;
      border-radius: 6px;
      text-align: center;
      font-size: 13px;
      color: #8D99AE;
    }

    .staff-no-venue {
      padding: 24px;
      background: #FEF3C7;
      border: 1px solid #FDE68A;
      border-radius: 8px;
      font-size: 13px;
      color: #92400E;
    }

    .staff-card {
      overflow: hidden;
    }

    @media (max-width: 900px) {
      .staff-settings-sidebar {
        display: none;
      }

      .staff-header {
        padding: 12px 16px;
        flex-wrap: wrap;
        gap: 12px;
      }

      .staff-section-header {
        padding: 16px;
      }

      .staff-tabs-bar {
        padding: 0 16px;
        overflow-x: auto;
      }

      .staff-content-inner {
        padding: 16px;
        max-width: none;
      }
    }

    @media (max-width: 640px) {
      .staff-form-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .staff-form-label-col {
        padding-top: 0;
      }

      .staff-card-header {
        gap: 8px;
        padding: 12px;
      }

      .staff-badge {
        display: none;
      }

      .staff-expanded {
        padding: 16px 12px;
      }

      .staff-actions-row {
        justify-content: stretch;
      }

      .staff-save-btn {
        width: 100%;
      }
    }

    /* Large rounded input style (Figma) — used by Coach + Manager forms */
    .field-form {
      display: flex;
      flex-direction: column;
    }

    .field-row {
      display: grid;
      grid-template-columns: minmax(200px, 240px) minmax(0, 1fr);
      gap: 24px;
      align-items: center;
      padding: 20px 0;
      border-top: 1px solid #E7EBEF;
    }

    .field-row:first-child {
      border-top: none;
      padding-top: 4px;
    }

    .field-row--photo,
    .field-row--hours {
      align-items: flex-start;
    }

    .field-copy {
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
    }

    .field-label {
      font-size: 14px;
      font-weight: 600;
      color: #2B2D42;
      line-height: 20px;
    }

    .field-desc {
      font-size: 12px;
      line-height: 18px;
      color: #8D99AE;
      max-width: 225px;
    }

    .field-control {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
      flex-wrap: wrap;
    }

    .field-control--input {
      max-width: 344px;
      width: 100%;
    }

    .field-control--phone {
      max-width: 240px;
      width: 100%;
    }

    .field-input {
      width: 100%;
      height: 40px;
      padding: 0 14px;
      background: #FFFFFF;
      border: 1px solid #D9E1EA;
      border-radius: 8px;
      font-size: 14px;
      color: #2B2D42;
      line-height: 20px;
      outline: none;
      box-sizing: border-box;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .field-input:focus {
      border-color: #AAB6C5;
    }

    /* Profile picture Upload photo button + circular preview */
    .field-photo-row {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .field-photo-preview {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      flex-shrink: 0;
      background: #E5E7EB;
      color: #9CA3AF;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: 600;
      overflow: hidden;
    }

    .field-photo-preview img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .field-photo-trigger {
      height: 40px;
      padding: 0 16px;
      border: 1px dashed #D8DFE8;
      border-radius: 8px;
      background: #FFFFFF;
      color: #98A2B3;
      font-size: 13px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      box-sizing: border-box;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.03);
    }

    .field-photo-trigger:hover {
      border-color: #C7D0DB;
      color: #64748B;
    }

    .field-photo-input {
      position: fixed;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      border: 0;
    }

    /* Sport pill group */
    .field-pill-group {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .field-pill {
      height: 34px;
      padding: 0 14px;
      border-radius: 8px;
      border: 1px solid #D9E1EA;
      background: #FFFFFF;
      color: #94A3B8;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      box-sizing: border-box;
      transition: all 0.15s ease;
    }

    .field-pill.active {
      background: #2B2D42;
      border-color: #2B2D42;
      color: #FFFFFF;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
    }

    /* Hours */
    .field-hours {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: flex-start;
    }

    .field-switch-line {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      font-weight: 500;
      color: #2B2D42;
    }

    .field-toggle {
      position: relative;
      width: 40px;
      height: 22px;
      flex-shrink: 0;
    }

    .field-toggle input {
      opacity: 0;
      width: 0;
      height: 0;
      position: absolute;
    }

    .field-toggle-slider {
      position: absolute;
      inset: 0;
      background: #D1D5DB;
      border-radius: 999px;
      transition: background 0.2s;
    }

    .field-toggle-slider::before {
      content: '';
      position: absolute;
      width: 16px;
      height: 16px;
      left: 3px;
      top: 3px;
      background: #FFFFFF;
      border-radius: 50%;
      transition: transform 0.2s;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.18);
    }

    .field-toggle input:checked+.field-toggle-slider {
      background: #2B2D42;
    }

    .field-toggle input:checked+.field-toggle-slider::before {
      transform: translateX(18px);
    }

    .field-time-range {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .field-time-input {
      width: 132px;
      height: 40px;
      padding: 0 14px;
      background: #FFFFFF;
      border: 1px solid #D9E1EA;
      border-radius: 8px;
      font-size: 14px;
      color: #2B2D42;
      box-sizing: border-box;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .field-time-sep {
      font-size: 13px;
      color: #98A2B3;
      flex-shrink: 0;
    }

    .field-save-row {
      display: flex;
      justify-content: flex-end;
      padding-top: 12px;
      gap: 8px;
    }

    /* Availability per-day grid */
    .avail-card {
      width: 100%;
      border: 1px solid #E7EBEF;
      border-radius: 12px;
      background: #FFFFFF;
      padding: 16px 20px;
      box-sizing: border-box;
    }

    .avail-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }

    .avail-header-title {
      font-size: 14px;
      font-weight: 600;
      color: #2B2D42;
    }

    .avail-apply-line {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: #8D99AE;
    }

    .avail-grid {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .avail-row {
      display: grid;
      grid-template-columns: minmax(140px, 180px) minmax(0, 1fr) minmax(0, 1fr);
      gap: 10px;
      align-items: center;
    }

    .avail-day-cell {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      border: 1px solid #1f2937ad;
      border-radius: 8px;
      background: #9fa0e62f;
    }

    .avail-day-cell.disabled {
      background: #FFFFFF;
      border-color: #E7EBEF;
    }

    .avail-check {
      width: 18px;
      height: 18px;
      border-radius: 4px;
      border: 1px solid #D9E1EA;
      appearance: none;
      -webkit-appearance: none;
      background: #FFFFFF;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .avail-check:checked {
      background: #2B2D42;
      border-color: #2B2D42;
    }

    .avail-check:checked::after {
      content: '';
      width: 10px;
      height: 6px;
      border: 2px solid #FFFFFF;
      border-top: 0;
      border-right: 0;
      transform: rotate(-45deg);
      margin-top: -2px;
    }

    .avail-day-label {
      font-size: 13px;
      font-weight: 500;
      color: #2B2D42;
    }

    .avail-time-input {
      height: 36px;
      padding: 0 12px 0 34px;
      background: #FFFFFF;
      border: 1px solid #D9E1EA;
      border-radius: 8px;
      font-size: 13px;
      color: #2B2D42;
      width: 100%;
      box-sizing: border-box;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.03);
    }

    .avail-time-input:disabled {
      background: #F8F9FB;
      color: #B8C1CC;
      cursor: not-allowed;
    }

    .avail-time-input.avail-time-locked {
      background: #F8F9FB;
      color: #B8C1CC;
      border-color: #E7EBEF;
      cursor: not-allowed;
      pointer-events: none;
      user-select: none;
    }

    .avail-time-wrap {
      position: relative;
    }

    .avail-time-icon {
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      width: 16px;
      height: 16px;
      color: #94A3B8;
      pointer-events: none;
    }

    /* ── Pricing variants (Coach only) ── */
    .field-row--prices {
      align-items: flex-start;
    }

    .price-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 100%;
    }

    .price-row {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .price-input-wrap {
      position: relative;
      width: 110px;
      flex-shrink: 0;
    }

    .price-currency {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 13px;
      font-weight: 500;
      color: #94A3B8;
      pointer-events: none;
    }

    .price-input {
      width: 100%;
      height: 36px;
      padding: 0 10px 0 26px;
      background: #FFFFFF;
      border: 1px solid #D9E1EA;
      border-radius: 8px;
      font-size: 13px;
      color: #2B2D42;
      box-sizing: border-box;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.03);
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .price-input:focus {
      border-color: #2B2D42;
      box-shadow: 0 0 0 3px rgba(43, 45, 66, 0.08);
    }

    .price-input::placeholder {
      color: #B8C1CC;
    }

    /* Strip default number-spinner so it matches the design */
    .price-input::-webkit-outer-spin-button,
    .price-input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
