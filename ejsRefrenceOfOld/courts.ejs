<div class="rounded-xl shadow-md bg-white overflow-hidden">
  <div class="p-6 border-b border-gray-200">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <h3 class="text-lg font-semibold text-gray-800">Courts List</h3>
      <a href="/admin/courts/add" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 text-sm font-medium whitespace-nowrap">
        Add Court
      </a>
    </div>
  </div>
  <div class="overflow-x-auto">
    <table id="courts-table" class="w-full text-sm">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Venue</th>
          <th>Sport Type</th>
          <th>Image</th>
          <th>Created By</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>
</div>

<script>
  var SPORT_IDS = { 1: 'Tennis', 2: 'Padel', 3: 'Pickleball' };

  var courtsTable;
  $(document).ready(function() {
    courtsTable = $('#courts-table').DataTable({
      processing: true,
      serverSide: true,
      ajax: '/admin/courts/datatable',
      order: [[6, 'desc']],
      pageLength: 10,
      columns: [
        { data: 'id' },
        { data: 'title' },
        {
          data: 'venue_name',
          orderable: false,
          render: function(data) {
            return '<span class="inline-flex px-2 py-1 text-xs font-medium rounded bg-purple-100 text-purple-700">' + (data || '-') + '</span>';
          }
        },
        {
          data: 'sport_type',
          orderable: false,
          render: function(data) {
            if (!data) return '<span class="text-gray-400">-</span>';
            var ids = data.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
            var names = ids.map(function(id) { return SPORT_IDS[id] || id; });
            return '<span class="text-gray-700">' + names.join(', ') + '</span>';
          }
        },
        {
          data: 'image',
          orderable: false,
          searchable: false,
          render: function(data) {
            if (!data) return '<span class="text-gray-400">-</span>';
            return '<img src="/' + data + '" alt="Court" class="w-10 h-10 object-cover rounded border" />';
          }
        },
        {
          data: 'created_by',
          orderable: false,
          searchable: false,
          render: function(data) {
            return '<span class="inline-flex px-2 py-1 text-xs font-medium rounded bg-blue-100 text-blue-700">' + (data || 'Admin') + '</span>';
          }
        },
        {
          data: 'createdAt',
          render: function(data) {
            return window.formatDateDMY(data);
          }
        },
        {
          data: null,
          orderable: false,
          searchable: false,
          render: function(data, type, row) {
            return '<div class="flex gap-2">' +
              '<a href="/admin/courts/' + row.id + '/detail" class="px-3 py-1.5 bg-green-100 text-green-700 rounded-md hover:bg-green-600 hover:text-white transition-colors text-xs font-medium">View</a>' +
              '<a href="/admin/courts/' + row.id + '/edit" class="px-3 py-1.5 bg-primary/10 text-primary rounded-md hover:bg-primary hover:text-white transition-colors text-xs font-medium">Edit</a>' +
              '<button type="button" onclick="deleteCourt(' + row.id + ')" class="px-3 py-1.5 bg-red-100 text-red-600 rounded-md hover:bg-red-600 hover:text-white transition-colors text-xs font-medium">Delete</button>' +
              '</div>';
          }
        }
      ],
      language: {
        processing: '<div class="flex items-center gap-2 text-gray-500"><svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Loading...</div>',
        emptyTable: 'No courts found',
        zeroRecords: 'No matching courts found'
      }
    });
  });

  function deleteCourt(id) {
    window.ajaxDelete('/admin/courts/' + id + '/delete', 'Delete Court?', 'This court will be soft deleted.', courtsTable);
  }
</script>
