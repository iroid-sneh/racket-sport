<% var currentPage = 'membership-plans'; %>

<style>
  .mp-wrapper { display: flex; flex-direction: column; min-height: calc(100vh - 0px); }

  .mp-title-section {
    background: #FFFFFF; padding: 20px 32px; border-bottom: 1px solid #E7EBEF;
    display: flex; align-items: flex-start; justify-content: space-between;
  }
  .mp-title-section h1 { font-size: 18px; font-weight: 700; color: #2B2D42; line-height: 1.4; }
  .mp-title-section p { font-size: 13px; color: #8D99AE; margin-top: 2px; }
  .mp-add-btn {
    display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px;
    background: #2B2D42; border: none; border-radius: 8px;
    font-size: 13px; font-weight: 500; color: #FFFFFF; cursor: pointer; white-space: nowrap;
    text-decoration: none; box-shadow: 0px 1px 2px rgba(0,0,0,0.1);
  }
  .mp-add-btn:hover { background: #1a1b2e; color: #FFFFFF; }

  .mp-content { background: #F2F4F7; flex: 1; padding: 24px 32px; }

  .mp-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px; max-width: 1100px;
  }

  .mp-card {
    background: #FFFFFF; border: 1px solid #E7EBEF; border-radius: 12px;
    position: relative; overflow: hidden; display: flex; flex-direction: column;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .mp-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(15, 23, 42, 0.12);
    border-color: #D6DAE3;
  }
  .mp-card.is-inactive { opacity: 0.65; }

  .mp-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }

  .mp-card-top {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 12px; margin-bottom: 10px;
  }
  .mp-card-name {
    font-size: 18px; font-weight: 700; color: #0F172A; line-height: 1.3;
    word-break: break-word;
  }
  .mp-card-actions { display: flex; gap: 6px; flex-shrink: 0; }
  .mp-icon-btn {
    width: 30px; height: 30px; border-radius: 6px; border: 1px solid #E7EBEF;
    background: #fff; display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.15s; text-decoration: none;
  }
  .mp-icon-btn:hover { background: #F2F4F7; border-color: #D6DAE3; }
  .mp-icon-btn.delete:hover { background: #FEF2F2; border-color: #FECACA; }

  .mp-card-type {
    display: inline-flex; align-items: center; align-self: flex-start;
    font-size: 11px; font-weight: 700; padding: 3px 10px;
    border-radius: 999px; letter-spacing: 0.5px; text-transform: uppercase;
    margin-bottom: 14px;
  }
  .mp-card-type.basic { background: #EEF2FF; color: #4F46E5; }
  .mp-card-type.premium { background: #FEF3C7; color: #B45309; }

  .mp-card-price-row {
    display: flex; align-items: baseline; gap: 1px; margin-bottom: 16px;
  }
  .mp-price-symbol { font-size: 17px; font-weight: 600; color: #0F172A; }
  .mp-price-num { font-size: 28px; font-weight: 700; color: #0F172A; line-height: 1; }
  .mp-price-period { font-size: 14px; font-weight: 400; color: #64748B; margin-left: 3px; }

  .mp-divider { height: 1px; background: #EEF2F6; margin: 0 0 14px; }

  .mp-benefits-list { list-style: none; padding: 0; margin: 0; }
  .mp-benefits-list li {
    font-size: 13px; color: #334155; padding: 3px 0; line-height: 1.45;
    display: flex; align-items: flex-start; gap: 8px;
  }
  .mp-check { color: #059669; width: 14px; height: 14px; flex-shrink: 0; margin-top: 3px; }
  .mp-benefits-more {
    font-size: 12px; color: #6366F1; font-weight: 500;
    margin-top: 6px; padding-left: 22px;
  }

  .mp-empty {
    text-align: center; padding: 80px 20px; max-width: 900px;
    background: #FFFFFF; border: 1px dashed #d1d5db; border-radius: 10px;
  }
  .mp-empty p { font-size: 15px; color: #8D99AE; margin-bottom: 16px; }
</style>

<div class="mp-wrapper">
  <div class="mp-title-section">
    <div>
      <h1>Membership</h1>
      <p>Membership tiers apply across all locations.</p>
    </div>
    <a href="/admin/membership-plans/add" class="mp-add-btn">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add Plan
    </a>
  </div>

  <div class="mp-content">
    <% if (typeof plans !== 'undefined' && plans.length > 0) { %>
      <div class="mp-grid">
        <% plans.forEach(function(plan) { %>
          <%
            var tierClass = plan.membership_type == 2 ? 'premium' : 'basic';
            var tierLabel = plan.membership_type == 2 ? 'Premium' : 'Basic';
            var benefits = plan.benefits ? plan.benefits.split('\n').map(function(b){return b.trim();}).filter(function(b){return b;}) : [];
            var visibleBenefits = benefits.slice(0, 4);
            var extraBenefits = benefits.length - visibleBenefits.length;
            var priceDisplay = (plan.price || 0).toFixed(2);
            var durationPeriod = plan.duration_type === 'end_date' && plan.end_date
              ? 'Until ' + new Date(plan.end_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
              : '/' + plan.duration_months + ' month' + (plan.duration_months > 1 ? 's' : '');
          %>
          <div class="mp-card <%= tierClass %><%= plan.is_active === false ? ' is-inactive' : '' %>" id="mp-card-<%= plan.id %>">
            <div class="mp-card-body">
              <div class="mp-card-top">
                <div style="min-width:0;flex:1;">
                  <div class="mp-card-name"><%= plan.name %></div>
                </div>
                <div class="mp-card-actions">
                  <a href="/admin/membership-plans/<%= plan.id %>/edit" class="mp-icon-btn" title="Edit">
                    <svg width="13" height="13" fill="none" stroke="#64748B" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </a>
                  <button type="button" class="mp-icon-btn delete" onclick="mpDeletePlan(<%= plan.id %>)" title="Delete">
                    <svg width="13" height="13" fill="none" stroke="#EF4444" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </div>
              </div>

              <span class="mp-card-type <%= tierClass %>"><%= tierLabel %></span>

              <div class="mp-card-price-row">
                <span class="mp-price-symbol">&pound;</span>
                <span class="mp-price-num"><%= priceDisplay %></span>
                <span class="mp-price-period"><%= durationPeriod %></span>
              </div>

              <% if (benefits.length) { %>
                <div class="mp-divider"></div>
                <ul class="mp-benefits-list">
                  <% visibleBenefits.forEach(function(benefit) { %>
                    <li>
                      <svg class="mp-check" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      <span><%= benefit %></span>
                    </li>
                  <% }); %>
                </ul>
                <% if (extraBenefits > 0) { %>
                  <div class="mp-benefits-more">+ <%= extraBenefits %> more</div>
                <% } %>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="mp-empty" id="mp-empty-state">
        <p>No membership plans yet</p>
      </div>
    <% } %>
  </div>
</div>

<script>
  function mpDeletePlan(id) {
    Swal.fire({
      title: 'Delete Plan?',
      text: 'This membership plan will be permanently deleted.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#DC2626',
      cancelButtonColor: '#6b7280',
      confirmButtonText: 'Yes, delete it'
    }).then(function(result) {
      if (!result.isConfirmed) return;
      fetch('/admin/membership-plans/' + id + '/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
      })
      .then(function(r) {
        if (!r.ok) {
          return r.text().then(function(text) {
            try { return JSON.parse(text); } catch(e) { return { success: false, message: 'Server error (' + r.status + ')' }; }
          });
        }
        return r.json();
      })
      .then(function(data) {
        if (data.success) {
          var card = document.getElementById('mp-card-' + id);
          if (card) {
            card.style.transition = 'opacity 0.3s, transform 0.3s';
            card.style.opacity = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(function() {
              card.remove();
              var grid = document.querySelector('.mp-grid');
              if (grid && grid.children.length === 0) {
                grid.remove();
                var content = document.querySelector('.mp-content');
                if (content) {
                  content.innerHTML = '<div class="mp-empty" id="mp-empty-state"><p>No membership plans yet</p></div>';
                }
              }
            }, 300);
          }
          window.ajaxSuccess('Membership plan deleted');
        } else {
          window.ajaxError(data.message || 'Failed to delete');
        }
      })
      .catch(function(err) { window.ajaxError(err.message || 'Something went wrong'); });
    });
  }
</script>
