<%
  var SPORT_IDS = { '1': 'Tennis', '2': 'Padel', '3': 'Pickleball' };
  var dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

  function getSportName(val) {
    if (!val) return '-';
    return val.split(',').map(function(s) { return SPORT_IDS[s.trim()] || s.trim(); }).join(', ');
  }

  function fmtDate(dt) {
    if (!dt) return '-';
    var d = new Date(dt);
    var dd = String(d.getDate()).padStart(2, '0');
    var mm = String(d.getMonth() + 1).padStart(2, '0');
    var yyyy = d.getFullYear();
    return dd + '-' + mm + '-' + yyyy;
  }

  function fmtTime12(t) {
    if (!t) return '-';
    var parts = t.split(':');
    var h = parseInt(parts[0]);
    var m = parts[1] || '00';
    var ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    return h + ':' + m + ' ' + ampm;
  }
%>

<!-- Back Button -->
<div class="mb-6">
  <a href="<%= basePath %>" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-primary transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Courts
  </a>
</div>

<div class="rounded-xl shadow-md bg-white overflow-hidden">
  <div class="p-6 border-b border-gray-200">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h3 class="text-xl font-bold text-gray-800"><%= court.title %></h3>
        <% if (court.venue) { %>
          <p class="text-sm text-gray-500 mt-1"><%= court.venue.title %></p>
        <% } %>
      </div>
      <a href="<%= basePath %>/<%= court.id %>/edit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 text-sm font-medium">
        Edit Court
      </a>
    </div>
  </div>

  <div class="p-6">
    <!-- Court Info Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">

      <!-- Venue -->
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Venue</p>
        <% if (court.venue) { %>
          <p class="text-sm font-medium text-gray-800"><%= court.venue.title %></p>
          <% if (court.venue.address) { %>
            <p class="text-xs text-gray-500 mt-0.5"><%= court.venue.address %></p>
          <% } %>
        <% } else { %>
          <p class="text-sm text-gray-400">-</p>
        <% } %>
      </div>

      <!-- Sport Type -->
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Sport Type</p>
        <p class="text-sm font-medium text-gray-800"><%= getSportName(court.sport_type) %></p>
      </div>

      <!-- Image -->
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Court Image</p>
        <% if (court.image) { %>
          <img src="/<%= court.image %>" alt="Court" class="w-20 h-20 object-cover rounded-lg border mt-1" />
        <% } else { %>
          <p class="text-sm text-gray-400">No image</p>
        <% } %>
      </div>

      <!-- Created By -->
      <div class="bg-gray-50 rounded-lg p-4">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Created By</p>
        <p class="text-sm font-medium text-gray-800"><%= court.owner ? court.owner.name : 'Admin' %></p>
      </div>

    </div>

    <!-- Weekly Schedule -->
    <div class="mt-8">
      <h4 class="text-md font-semibold text-gray-800 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Weekly Schedule
      </h4>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200 rounded-lg">
          <thead>
            <tr class="bg-gray-50">
              <th class="px-4 py-3 text-left font-medium text-gray-600">Day</th>
              <th class="px-4 py-3 text-center font-medium text-gray-600">Status</th>
              <th class="px-4 py-3 text-left font-medium text-gray-600">Start Time</th>
              <th class="px-4 py-3 text-left font-medium text-gray-600">End Time</th>
              <th class="px-4 py-3 text-left font-medium text-gray-600">Price (Per Hour)</th>
            </tr>
          </thead>
          <tbody>
            <% dayNames.forEach(function(dayName, idx) {
              var sched = scheduleMap[idx] || {};
              var isOpen = sched.is_open || false;
            %>
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3 font-medium text-gray-800"><%= dayName %></td>
                <td class="px-4 py-3 text-center">
                  <% if (isOpen) { %>
                    <span class="inline-flex px-2 py-1 text-xs font-medium rounded bg-green-100 text-green-700">Open</span>
                  <% } else { %>
                    <span class="inline-flex px-2 py-1 text-xs font-medium rounded bg-red-100 text-red-600">Closed</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-gray-700"><%= isOpen ? fmtTime12(sched.start_time) : '-' %></td>
                <td class="px-4 py-3 text-gray-700"><%= isOpen ? fmtTime12(sched.end_time) : '-' %></td>
                <td class="px-4 py-3">
                  <% if (isOpen) { %>
                    <span class="font-medium text-green-700"><%= (sched.price || 0).toFixed(2) %></span>
                  <% } else { %>
                    <span class="text-gray-400">-</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-6 pt-4 border-t border-gray-100 flex justify-between items-center">
      <p class="text-xs text-gray-400">Created: <%= fmtDate(court.createdAt) %></p>
      <p class="text-xs text-gray-400">ID: #<%= court.id %></p>
    </div>
  </div>
</div>
